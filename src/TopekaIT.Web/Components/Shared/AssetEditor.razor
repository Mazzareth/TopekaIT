@using TopekaIT.Core.Domain.Entities
@using TopekaIT.Core.Domain.Enums
@using TopekaIT.Core.Services
@using System.Security.Claims
@inject AssetService AssetService
@inject AssetModelService AssetModelService
@inject AuthenticationStateProvider AuthProvider
@inject AccessControlService Access

@code {
    [Parameter] public bool Open { get; set; }
    [Parameter] public string? PrefillSerial { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback OnChanged { get; set; }

    Asset _draft = new();
    string? _error;
    bool _saving;
    bool _wasOpen;
    List<AssetModel> _models = new();
    bool _addingNewModel;
    bool _canCreateAssets;
    bool _canManageModels;
    string _newModelName = "";

    string TagAndSerial
    {
        get => _draft.Tag;
        set
        {
            _draft.Tag = value;
            _draft.Serial = value;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        _models = (await AssetModelService.GetAllAsync()).ToList();
        var auth = await AuthProvider.GetAuthenticationStateAsync();
        var userId = auth.User.FindFirst(ClaimTypes.NameIdentifier)?.Value ?? "";
        var access = await Access.GetUserAccessAsync(userId);
        _canCreateAssets = access?.Has(AccessPermissionKeys.AssetsCreate) == true;
        _canManageModels = access?.Has(AccessPermissionKeys.AssetsManageModels) == true;
    }

    protected override void OnParametersSet()
    {
        if (Open && !_wasOpen)
        {
            _draft = new Asset
            {
                Id       = Guid.NewGuid().ToString("N")[..16],
                Category = AssetCategory.SaeDevice,
                Type     = "sae",
                Quantity = 1,
                Status   = AssetStatus.In,
                Tag      = PrefillSerial ?? "",
                Serial   = PrefillSerial ?? "",
            };
            _error  = null;
            _saving = false;
        }
        _wasOpen = Open;
    }

    async Task Save()
    {
        if (_draft.Category == AssetCategory.PodTc77 && string.IsNullOrWhiteSpace(_draft.Serial))
        {
            _error = "TC77 POD devices require a serial number.";
            return;
        }

        if (_draft.Category != AssetCategory.Battery && string.IsNullOrWhiteSpace(_draft.Tag) && string.IsNullOrWhiteSpace(_draft.Serial))
        {
            _error = "Tracked devices need an asset tag or serial number.";
            return;
        }

        if (_draft.Category == AssetCategory.Battery && _draft.Quantity < 0)
        {
            _error = "Battery quantity cannot be negative.";
            return;
        }

        _saving = true;
        _error = null;
        try
        {
            if (!_canCreateAssets)
            {
                _error = "You do not have access to create assets.";
                return;
            }

            await AssetService.AddAsync(_draft);
            await OnChanged.InvokeAsync();
            Close();
        }
        catch (Exception ex)
        {
            _error = "Failed to save asset: " + ex.Message;
        }
        finally
        {
            _saving = false;
        }
    }

    void Close()
    {
        _draft    = new();
        _wasOpen  = false;
        OnClose.InvokeAsync();
    }

    async Task AddNewModel()
    {
        if (string.IsNullOrWhiteSpace(_newModelName)) return;
        if (!_canManageModels) return;
        var modelName = _newModelName.Trim();
        await AssetModelService.AddAsync(modelName);
        _models = (await AssetModelService.GetAllAsync()).ToList();
        _draft.Model = modelName;
        _addingNewModel = false;
        _newModelName = "";
    }

    void CancelNewModel()
    {
        _addingNewModel = false;
        _newModelName = "";
    }

    void ModelChanged(ChangeEventArgs e)
    {
        var value = e.Value?.ToString() ?? "";
        if (value == "__add_new__")
        {
            if (!_canManageModels) return;
            _draft.Model = "";
            _addingNewModel = true;
            return;
        }

        _draft.Model = value;
        _addingNewModel = false;
    }

    void CategoryChanged(ChangeEventArgs e)
    {
        if (Enum.TryParse<AssetCategory>(e.Value?.ToString(), out var category))
        {
            _draft.Category    = category;
            _draft.ScannerKind = category == AssetCategory.Scanner ? ScannerKind.TwoD : null;
            _draft.Status      = category switch
            {
                AssetCategory.PodTc77  => AssetStatus.InUse,
                AssetCategory.Battery  => AssetStatus.Spare,
                AssetCategory.Scanner  => AssetStatus.In,
                _                      => AssetStatus.In,
            };
            _draft.Quantity = category == AssetCategory.Battery ? Math.Max(_draft.Quantity, 1) : 1;
        }
    }
}

<Modal Open="Open" OnClose="Close">
    <Title>
        <span class="modal-title-icon">
            <Icon Name="Plus" Size="16" /> Add new asset
        </span>
    </Title>
    <ChildContent>
        <div class="asset-editor">
            <div class="form-row">
                <label>Type</label>
                <select value="@_draft.Category" @onchange="CategoryChanged">
                    <option value="@AssetCategory.SaeDevice">SAE device</option>
                    <option value="@AssetCategory.PodTc77">TC77 POD</option>
                    <option value="@AssetCategory.Scanner">Scanner</option>
                    <option value="@AssetCategory.Battery">Battery</option>
                </select>
            </div>
            
            @if (_draft.Category == AssetCategory.SaeDevice)
            {
                <div class="form-row">
                    <label>S/N / Asset ID</label>
                    <input @bind="TagAndSerial" placeholder="e.g. 123456789" autocomplete="off" />
                </div>
                <div class="form-row">
                    <label>Model</label>
                    @if (_addingNewModel)
                    {
                        <div class="inline-action-row">
                            <input @bind="_newModelName" @bind:event="oninput" placeholder="New model name" autocomplete="off" />
                            <button type="button" class="btn btn-primary" @onclick="AddNewModel">Add</button>
                            <button type="button" class="btn btn-ghost" @onclick="CancelNewModel">Cancel</button>
                        </div>
                    }
                    else
                    {
                        <select value="@_draft.Model" @onchange="ModelChanged">
                            <option value="">(Select model)</option>
                            @foreach (var m in _models)
                            {
                                <option value="@m.Name">@m.Name</option>
                            }
                            @if (_canManageModels)
                            {
                                <option value="__add_new__">Add new model…</option>
                            }
                        </select>
                    }
                </div>
            }
            else if (_draft.Category == AssetCategory.Scanner)
            {
                <div class="form-row">
                    <label>Serial Number</label>
                    <input @bind="_draft.Serial" placeholder="e.g. S23A00123" autocomplete="off" />
                </div>
                <div class="form-row">
                    <label>Asset Tag <span class="label-note">optional</span></label>
                    <input @bind="_draft.Tag" placeholder="e.g. SCN-0042" autocomplete="off" />
                </div>
                <div class="form-row">
                    <label>Scanner kind</label>
                    <select @bind="_draft.ScannerKind">
                        <option value="@ScannerKind.TwoD">2D (area imager)</option>
                        <option value="@ScannerKind.OneD">1D (laser)</option>
                        <option value="@ScannerKind.Ring">Ring scanner</option>
                        <option value="@ScannerKind.Other">Other</option>
                    </select>
                </div>
                <div class="form-row">
                    <label>Model <span class="label-note">optional</span></label>
                    <input @bind="_draft.Model" placeholder="e.g. RS5100, RS6100" autocomplete="off" />
                </div>
            }
            else
            {
                <div class="form-row">
                    <label>Asset Tag <span class="label-note">optional for batteries</span></label>
                    <input @bind="_draft.Tag" placeholder="e.g. WD-0123 or BAT-CASE-A" autocomplete="off" />
                </div>
                <div class="form-row">
                    <label>Model <span class="label-note">optional</span></label>
                    <input @bind="_draft.Model" placeholder="e.g. Zebra WS50, TC77, or battery model" autocomplete="off" />
                </div>
                <div class="form-row">
                    <label>Serial Number @(_draft.Category == AssetCategory.PodTc77 ? "" : "— optional")</label>
                    <input @bind="_draft.Serial" placeholder="@(_draft.Category == AssetCategory.PodTc77 ? "Required for TC77" : "Optional serial number")" autocomplete="off" />
                </div>
            }

            @if (_draft.Category == AssetCategory.PodTc77)
            {
                <div class="form-row">
                    <label>IMEI <span class="label-note">optional</span></label>
                    <input @bind="_draft.Imei" placeholder="Optional IMEI" autocomplete="off" />
                </div>
                <div class="form-row">
                    <label>Status</label>
                    <select @bind="_draft.Status">
                        <option value="@AssetStatus.InUse">In Use</option>
                        <option value="@AssetStatus.InRMA">RMA</option>
                        <option value="@AssetStatus.Investigating">Investigating</option>
                        <option value="@AssetStatus.Holding">Holding</option>
                    </select>
                </div>
            }
            else if (_draft.Category == AssetCategory.Battery)
            {
                <div class="form-row">
                    <label>Quantity</label>
                    <input type="number" min="0" step="1" @bind="_draft.Quantity" />
                </div>
                <div class="form-row">
                    <label>Status</label>
                    <select @bind="_draft.Status">
                        <option value="@AssetStatus.Spare">Spare</option>
                        <option value="@AssetStatus.Holding">Holding</option>
                        <option value="@AssetStatus.InUse">In Use</option>
                    </select>
                </div>
            }
            <div class="form-row">
                <label>Notes</label>
                <textarea @bind="_draft.Notes" placeholder="Equipment or Locker notes" style="height: 60px; font-family: inherit; font-size: 13px;"></textarea>
            </div>
            
            @if (!string.IsNullOrEmpty(_error))
            {
                <div class="form-error">@_error</div>
            }
        </div>
    </ChildContent>
    <Footer>
        <button class="btn btn-ghost" @onclick="Close" disabled="@_saving">Cancel</button>
        <button class="btn btn-primary" @onclick="Save" disabled="@(_saving || !_canCreateAssets)">Save asset</button>
    </Footer>
</Modal>
