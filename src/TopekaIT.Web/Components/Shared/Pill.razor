@* Tiny status label. Used everywhere a full sentence would slow the page down. *@
@code {
    [Parameter] public string Kind { get; set; } = "pill-dim";
    [Parameter] public bool Dot { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
}

<span class="pill @Kind">
    @if (Dot) { <i class="dot"></i> }
    @ChildContent
</span>
