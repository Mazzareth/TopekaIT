<ManualAssetLookupModal Open="Open"
                        OnClose="OnClose"
                        OnMatch="OnMatch"
                        IconName="Rfid"
                        Title="RFID Scan"
                        TitleClass="modal-title-icon"
                        Label="RFID reader value"
                        Placeholder="Scan NTAG213 or enter rfid:NTAG-..."
                        SubmitText="Select asset"
                        ErrorClass="form-error"
                        NotFoundMessage="RfidNotFoundMessage" />

@code {
    [Parameter] public bool Open { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback<Asset> OnMatch { get; set; }

    string RfidNotFoundMessage(string value) => $"No asset found for RFID value '{value}'.";
}
