@using System.Security.Claims
@using TopekaIT.Core.Domain.Entities
@using TopekaIT.Core.Services
@inject AssetService AssetService
@inject AuthenticationStateProvider AuthProvider
@inject AppState State

@code {
    [Parameter] public Asset? Asset { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback OnChanged { get; set; }

    string _manualValue = "";
    string? _error;
    string? _message;
    string _lastAssetKey = "";
    bool _saving;

    protected override void OnParametersSet()
    {
        var key = Asset?.Id ?? "";
        if (key != _lastAssetKey)
        {
            _lastAssetKey = key;
            _manualValue = Asset?.RfidTagId ?? "";
            _error = null;
            _message = null;
            _saving = false;
        }
    }

    string TokenForPreview => !string.IsNullOrWhiteSpace(_manualValue)
        ? _manualValue
        : Asset?.RfidTagId ?? "";

    string Payload => AssetService.BuildRfidPayload(TokenForPreview);
    int PayloadBytes => AssetService.GetPayloadByteCount(Payload);
    bool PayloadFits => PayloadBytes <= AssetService.Ntag213UserBytes;

    async Task Generate()
    {
        if (Asset == null) return;
        var actorName = await ActorNameAsync();
        await SaveWith(() => AssetService.GenerateRfidLinkAsync(Asset.Id, actorName));
    }

    async Task LinkManual()
    {
        if (Asset == null || string.IsNullOrWhiteSpace(_manualValue)) return;
        var actorName = await ActorNameAsync();
        await SaveWith(() => AssetService.LinkRfidAsync(Asset.Id, _manualValue, actorName));
    }

    async Task Clear()
    {
        if (Asset == null) return;
        var actorName = await ActorNameAsync();
        await SaveWith(() => AssetService.ClearRfidLinkAsync(Asset.Id, actorName));
    }

    async Task SaveWith(Func<Task<Asset?>> action)
    {
        _saving = true;
        _error = null;
        _message = null;
        try
        {
            var updated = await action();
            if (updated != null)
            {
                _manualValue = updated.RfidTagId ?? "";
                _message = string.IsNullOrWhiteSpace(updated.RfidTagId)
                    ? "RFID link cleared."
                    : "RFID tag linked.";
                State.PushToast(_message, "up");
                await OnChanged.InvokeAsync();
            }
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _saving = false;
        }
    }

    async Task<string> ActorNameAsync()
    {
        var auth = await AuthProvider.GetAuthenticationStateAsync();
        return auth.User.FindFirst("name")?.Value
            ?? auth.User.FindFirst(ClaimTypes.Name)?.Value
            ?? "Portal user";
    }

    async Task Close()
    {
        await OnClose.InvokeAsync();
    }
}

<Modal Open="@(Asset != null)" OnClose="Close" Wide>
    <Title>
        <span class="modal-title-icon">
            <Icon Name="Rfid" Size="16" /> RFID NTAG213
        </span>
    </Title>
    <ChildContent>
        @if (Asset != null)
        {
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;">
                <div style="padding:12px;background:var(--bg-sunken);border-radius:6px;">
                    <div style="font-size:10px;font-family:var(--mono);text-transform:uppercase;color:var(--text-faint);margin-bottom:6px;">Current Link</div>
                    @if (!string.IsNullOrWhiteSpace(Asset.RfidTagId))
                    {
                        <div class="mono" style="font-size:13px;">@Asset.RfidTagId</div>
                        @if (Asset.RfidLinkedAt.HasValue)
                        {
                            <div style="font-size:12px;color:var(--text-dim);margin-top:4px;">Linked @Format.RelTime(Asset.RfidLinkedAt.Value)</div>
                        }
                    }
                    else
                    {
                        <div style="font-size:13px;color:var(--text-dim);">No RFID tag linked</div>
                    }
                </div>

                <div style="padding:12px;background:var(--bg-sunken);border-radius:6px;">
                    <div style="font-size:10px;font-family:var(--mono);text-transform:uppercase;color:var(--text-faint);margin-bottom:6px;">NTAG213 Payload</div>
                    <div class="mono" style="font-size:13px;word-break:break-all;">@(string.IsNullOrWhiteSpace(Payload) ? "Generate a payload first" : Payload)</div>
                    <div style="font-size:12px;color:@(PayloadFits ? "var(--text-dim)" : "var(--down)");margin-top:4px;">
                        @PayloadBytes / @AssetService.Ntag213UserBytes bytes
                    </div>
                </div>
            </div>

            <div class="form-row" style="margin-top:14px;">
                <label>RFID UID or generated token</label>
                <input @bind="_manualValue"
                       @bind:event="oninput"
                       placeholder="Scan NTAG213 UID, paste reader value, or use generated token"
                       autocomplete="off"
                       spellcheck="false" />
            </div>

            @if (!string.IsNullOrWhiteSpace(_message))
            {
                <div style="font-size:12px;color:var(--text-dim);">@_message</div>
            }
            @if (!string.IsNullOrWhiteSpace(_error))
            {
                <div class="form-error">@_error</div>
            }
        }
    </ChildContent>
    <Footer>
        <button class="btn" @onclick="Generate" disabled="@_saving">
            <Icon Name="RefreshCw" Size="14" /> Generate link
        </button>
        <button class="btn" @onclick="LinkManual" disabled="@(_saving || string.IsNullOrWhiteSpace(_manualValue) || !PayloadFits)">
            <Icon Name="Link" Size="14" /> Link value
        </button>
        @if (!string.IsNullOrWhiteSpace(Asset?.RfidTagId))
        {
            <button class="btn btn-ghost" @onclick="Clear" disabled="@_saving">
                <Icon Name="Unlink" Size="14" /> Clear
            </button>
        }
    </Footer>
</Modal>
