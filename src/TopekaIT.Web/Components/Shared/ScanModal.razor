<ManualAssetLookupModal Open="Open"
                        OnClose="OnClose"
                        OnMatch="OnMatch"
                        IconName="Scan"
                        Title="Scan asset tag"
                        TitleStyle="display: flex; gap: 8px; align-items: center;"
                        Label="Scan or enter tag / serial / IMEI"
                        Placeholder="WD-0042, serial:12345, or scanned QR text"
                        SubmitText="Use tag"
                        ShowCancel="true"
                        ErrorStyle="font-size: 12px; color: var(--down); margin-top: 4px;" />

@code {
    [Parameter] public bool Open { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback<Asset> OnMatch { get; set; }
}
