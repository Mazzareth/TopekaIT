@code {
    [Parameter] public string Value { get; set; } = "";
    [Parameter] public bool Big { get; set; }

    private bool[] _cells = Array.Empty<bool>();
    private const int _size = 21;
    private string _lastValue = "";

    protected override void OnParametersSet()
    {
        if (_lastValue == Value && _cells.Length > 0) return;
        _lastValue = Value;
        _cells = Build(Value);
    }

    private static bool[] Build(string value)
    {
        uint h = 2166136261u;
        for (int i = 0; i < value.Length; i++)
        {
            h ^= value[i];
            h = h * 16777619u;
        }
        var cells = new bool[_size * _size];
        for (int i = 0; i < cells.Length; i++)
        {
            int x = i % _size, y = i / _size;

            if (InCorner(x, y, 0, 0)) { cells[i] = FinderCell(x, y, 0, 0); continue; }
            if (InCorner(x, y, 14, 0)) { cells[i] = FinderCell(x, y, 14, 0); continue; }
            if (InCorner(x, y, 0, 14)) { cells[i] = FinderCell(x, y, 0, 14); continue; }

            if (y == 6 || x == 6) { cells[i] = (x + y) % 2 == 0; continue; }

            h ^= (uint)i;
            h = h * 16777619u;
            cells[i] = (h % 100) < 48;
        }
        return cells;
    }

    private static bool InCorner(int x, int y, int cx, int cy)
        => x >= cx && x < cx + 7 && y >= cy && y < cy + 7;

    private static bool FinderCell(int x, int y, int cx, int cy)
    {
        int lx = x - cx, ly = y - cy;
        bool outer = lx == 0 || lx == 6 || ly == 0 || ly == 6;
        bool inner = lx >= 2 && lx <= 4 && ly >= 2 && ly <= 4;
        return outer || inner;
    }
}

<div class="qr @(Big ? "qr-big" : "")">
    @for (int i = 0; i < _cells.Length; i++)
    {
        var on = _cells[i];
        <div class="@(on ? "" : "off")"></div>
    }
</div>
