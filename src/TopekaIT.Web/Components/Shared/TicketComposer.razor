@using TopekaIT.Core.Services
@using System.Security.Claims
@inject TicketService TicketService
@inject AuthenticationStateProvider AuthProvider
@inject AppState State
@inject PrinterService PrinterService
@inject AssetService AssetService

@code {
    [Parameter] public bool Open { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback<Ticket> OnSubmitted { get; set; }
    [Parameter] public string? PresetAssetType { get; set; }
    [Parameter] public string? PresetAssetId { get; set; }
    [Parameter] public string? PresetTitle { get; set; }
    [Parameter] public string? PresetDescription { get; set; }

    string _title = "";
    string _desc = "";
    string _assetRef = "";
    string? _reporterName;
    List<Printer> _printers = new();
    List<Asset> _assets = new();
    bool _loaded;

    protected override async Task OnParametersSetAsync()
    {
        if (Open && !_loaded)
        {
            _loaded = true;
            _printers = (await PrinterService.GetAllAsync()).ToList();
            _assets = (await AssetService.GetAllAsync()).ToList();
            var auth = await AuthProvider.GetAuthenticationStateAsync();
            _reporterName = auth.User.FindFirst("name")?.Value ?? auth.User.Identity?.Name;
        }
        if (Open)
        {
            // Reset fields on each open
            if (string.IsNullOrEmpty(_title) && string.IsNullOrEmpty(_desc))
            {
                _title = PresetTitle ?? "";
                _desc = PresetDescription ?? "";
                _assetRef = PresetAssetType != null && PresetAssetId != null ? $"{PresetAssetType}:{PresetAssetId}" : "";
            }
        }
    }

    async Task Submit()
    {
        if (string.IsNullOrWhiteSpace(_title)) return;
        AssetKind? kind = null;
        string? id = null;
        if (!string.IsNullOrEmpty(_assetRef))
        {
            var parts = _assetRef.Split(':');
            if (parts.Length == 2)
            {
                kind = parts[0] == "printer" ? AssetKind.Printer : AssetKind.Asset;
                id = parts[1];
            }
        }
        var auth = await AuthProvider.GetAuthenticationStateAsync();
        var userId = auth.User.FindFirst(ClaimTypes.NameIdentifier)?.Value ?? "";
        var ticket = await TicketService.CreateAsync(_title, _desc, id, kind, userId);
        State.PushToast($"Request {ticket.Id} submitted", "up");
        await OnSubmitted.InvokeAsync(ticket);
        _title = ""; _desc = ""; _assetRef = "";
        await OnClose.InvokeAsync();
    }

    async Task Close()
    {
        _title = ""; _desc = ""; _assetRef = "";
        await OnClose.InvokeAsync();
    }

    static string AssetOption(Asset asset)
    {
        var label = !string.IsNullOrWhiteSpace(asset.Tag)
            ? asset.Tag
            : !string.IsNullOrWhiteSpace(asset.Serial)
                ? asset.Serial
                : asset.Id;
        var model = string.IsNullOrWhiteSpace(asset.Model) ? asset.Category.ToString() : asset.Model;
        return asset.Category == AssetCategory.Battery
            ? $"{label} · {model} x{asset.Quantity}"
            : $"{label} · {model}";
    }
}

<Modal Open="Open" OnClose="Close">
    <Title>New IT request</Title>
    <ChildContent>
        <div class="form-row">
            <label>Title</label>
            <input @bind="_title" @bind:event="oninput" autofocus placeholder="Short summary — e.g. Printer jammed in pick area" />
        </div>
        <div class="form-row">
            <label>Affected asset <span style="color: var(--text-faint); text-transform: none; letter-spacing: 0;">— optional</span></label>
            <select @bind="_assetRef">
                <option value="">None / not related to an asset</option>
                <optgroup label="Printers">
                    @foreach (var p in _printers)
                    {
                        <option value="@($"printer:{p.Id}")">@p.Name · @p.Model</option>
                    }
                </optgroup>
                <optgroup label="SAE Devices">
                    @foreach (var a in _assets.Where(a => a.Category == AssetCategory.SaeDevice))
                    {
                        <option value="@($"asset:{a.Id}")">@AssetOption(a)</option>
                    }
                </optgroup>
                <optgroup label="POD TC77s">
                    @foreach (var a in _assets.Where(a => a.Category == AssetCategory.PodTc77))
                    {
                        <option value="@($"asset:{a.Id}")">@AssetOption(a)</option>
                    }
                </optgroup>
                <optgroup label="Batteries">
                    @foreach (var a in _assets.Where(a => a.Category == AssetCategory.Battery))
                    {
                        <option value="@($"asset:{a.Id}")">@AssetOption(a)</option>
                    }
                </optgroup>
            </select>
        </div>
        <div class="form-row">
            <label>Description</label>
            <textarea @bind="_desc" @bind:event="oninput" placeholder="What's happening? Steps to reproduce, error messages, anything that might help IT."></textarea>
        </div>
        <div style="font-size: 12px; color: var(--text-faint); display: flex; gap: 6px; align-items: center;">
            <Icon Name="User" Size="12" /> Submitted as <b style="color: var(--text-dim);">@_reporterName</b>
        </div>
    </ChildContent>
    <Footer>
        <button class="btn btn-ghost" @onclick="Close">Cancel</button>
        <button class="btn btn-accent" @onclick="Submit" disabled="@string.IsNullOrWhiteSpace(_title)">
            <Icon Name="Plus" Size="14" /> Submit request
        </button>
    </Footer>
</Modal>
