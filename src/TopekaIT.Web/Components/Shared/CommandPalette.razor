@* Global command palette. It is the keyboard shortcut for jumping to common portal work. *@
@implements IDisposable
@inject AppState State
@inject IJSRuntime JS
@inject NavigationManager Nav
@inject ITenantContext TenantContext
@inject PrinterService Printers
@inject TicketService Tickets
@inject AssetService AssetSvc
@inject UserService Users
@inject DivisionService Divisions

@if (State.CommandPaletteOpen)
{
    <div class="cmdk-backdrop" @onclick="Close">
        <section class="cmdk" role="dialog" aria-modal="true" aria-label="Command palette" @onclick:stopPropagation="true">
            <div class="cmdk__input">
                <Icon Name="Search" Size="14" />
                <input @ref="_searchInput"
                       value="@_query"
                       @oninput="OnQueryChanged"
                       @onkeydown="HandleKeyDown"
                       placeholder="Search printers, assets, tickets, people..."
                       autocomplete="off" />
                <kbd>esc</kbd>
            </div>
            @if (_loading)
            {
                <div class="cmdk__empty">Loading commands.</div>
            }
            else if (DisplayItems.Count == 0)
            {
                <div class="cmdk__empty">No matching printers, assets, tickets, people, or divisions.</div>
            }
            else
            {
                @foreach (var group in DisplayItems.Select((Item, Index) => new { Item, Index }).GroupBy(i => i.Item.Group))
                {
                    <div class="cmdk__section">@group.Key</div>
                    @foreach (var result in group)
                    {
                        <button type="button"
                                class="@RowClass(result.Index)"
                                aria-selected="@(result.Index == _selectedIndex)"
                                @onclick="() => Run(result.Item)">
                            <span class="cmdk__type @result.Item.Tone">@result.Item.ShortType</span>
                            <span>@result.Item.Label</span>
                            <span class="cmdk__sub">@result.Item.Meta</span>
                        </button>
                    }
                }
            }
        </section>
    </div>
}

@code {
    ElementReference _searchInput;
    DotNetObjectReference<CommandPalette>? _ref;
    bool _loaded;
    bool _loading;
    string _query = "";
    int _selectedIndex;
    List<CommandItem> _items = new();

    List<CommandItem> SearchItems => string.IsNullOrWhiteSpace(_query)
        ? _items.Take(18).ToList()
        : _items
            .Select(i => new { Item = i, Score = i.Score(_query) })
            .Where(i => i.Score > 0)
            .OrderByDescending(i => i.Score)
            .ThenBy(i => i.Item.Group)
            .ThenBy(i => i.Item.Label)
            .Select(i => i.Item)
            .Take(18)
            .ToList();

    List<CommandItem> DisplayItems => SearchItems
        .GroupBy(i => i.Group)
        .SelectMany(group => group)
        .ToList();

    protected override void OnInitialized()
    {
        State.OnChange += OnStateChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _ref = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("topekaCommand.register", _ref);
        }

        if (State.CommandPaletteOpen)
        {
            if (!_loaded && !_loading)
            {
                await LoadItems();
            }

            await JS.InvokeVoidAsync("topekaCommand.focus", _searchInput);
        }
    }

    void OnStateChanged()
    {
        _ = InvokeAsync(async () =>
        {
            if (State.CommandPaletteOpen && !_loaded && !_loading)
            {
                await LoadItems();
            }

            StateHasChanged();
        });
    }

    [JSInvokable]
    public void OpenFromKeyboard() => State.OpenCommandPalette();

    async Task LoadItems()
    {
        _loading = true;
        StateHasChanged();

        var items = new List<CommandItem>
        {
            new("JUMP", "Control room", "Operations dashboard", "Go", "jump", "/it"),
            new("JUMP", "Printers", TenantContext.IsResolved ? $"Fleet health and setup - {TenantContext.DivisionId}" : "Fleet health and setup", "Go", "jump", TenantContext.IsResolved ? "/it/printers" : "/admin"),
            new("JUMP", "Assets", TenantContext.IsResolved ? $"Inventory and scanner lookup - {TenantContext.DivisionId}" : "Inventory and scanner lookup", "Go", "jump", TenantContext.IsResolved ? "/it/assets" : "/admin"),
            new("JUMP", "Tickets", TenantContext.IsResolved ? $"Queue and active requests - {TenantContext.DivisionId}" : "Queue and active requests", "Go", "jump", TenantContext.IsResolved ? "/it/tickets" : "/admin"),
        };

        if (TenantContext.IsResolved)
        {
            var printers = await Printers.GetAllAsync();
            items.AddRange(printers.Select(p => new CommandItem(
                "PRINTERS",
                string.IsNullOrWhiteSpace(p.Name) ? p.IpAddress : p.Name,
                $"{p.IpAddress} - {TenantContext.DivisionId} - {p.Department} - {p.Status}",
                "Prn",
                p.Status == PrinterStatus.Down ? "is-critical" : p.Status == PrinterStatus.Warn ? "is-warning" : "is-ok",
                $"/it/printers/{p.Id}")));

            var tickets = await Tickets.GetAllAsync();
            items.AddRange(tickets
                .OrderByDescending(t => t.UpdatedAt)
                .Take(40)
                .Select(t => new CommandItem(
                    "TICKETS",
                    $"{t.Id} - {t.Title}",
                    $"{t.Priority} - {t.Status} - {Rel(t.CreatedAt)}",
                    "Tkt",
                    t.Priority == TicketPriority.Urgent ? "is-critical" : t.Priority == TicketPriority.High ? "is-warning" : "is-info",
                    "/it/tickets")));

            var assets = await AssetSvc.GetAllAsync();
            items.AddRange(assets.Select(a => new CommandItem(
                "ASSETS",
                string.IsNullOrWhiteSpace(a.Tag) ? a.Serial : a.Tag,
                $"{Format.CategoryLabel(a.Category)} - {a.Model} - {a.Status}",
                "Ast",
                a.Status is AssetStatus.Repair or AssetStatus.InRMA or AssetStatus.Investigating ? "is-warning" : "is-info",
                "/it/assets")));
        }

        var users = await Users.GetAllAsync();
        items.AddRange(users.Select(u => new CommandItem(
            "PEOPLE",
            u.Name,
            $"{u.Username} - {u.Role.DisplayName()} - {u.DivisionId ?? "global"}",
            "Usr",
            "is-user",
            u.Role >= AccessTier.SuperAdmin ? "/admin/users" : "/it/users")));

        var divisions = await Divisions.GetAllAsync();
        items.AddRange(divisions.Select(d => new CommandItem(
            "DIVISIONS",
            d.Name,
            $"{d.Id} - printer code {d.PrinterPasswordCode ?? "unset"}",
            "Div",
            "is-info",
            $"/admin/enter/{d.Id}")));

        _items = items;
        _loaded = true;
        _loading = false;
        ClampSelection();
    }

    void OnQueryChanged(ChangeEventArgs args)
    {
        _query = args.Value?.ToString() ?? "";
        _selectedIndex = 0;
        ClampSelection();
    }

    void HandleKeyDown(KeyboardEventArgs args)
    {
        if (args.Key == "Escape")
        {
            Close();
        }
        else if (args.Key == "ArrowDown")
        {
            MoveSelection(1);
        }
        else if (args.Key == "ArrowUp")
        {
            MoveSelection(-1);
        }
        else if (args.Key == "Enter" && SelectedItem() is { } item)
        {
            Run(item);
        }
    }

    void MoveSelection(int direction)
    {
        var items = DisplayItems;
        if (items.Count == 0)
        {
            _selectedIndex = 0;
            return;
        }

        _selectedIndex = (_selectedIndex + direction + items.Count) % items.Count;
    }

    CommandItem? SelectedItem()
    {
        var items = DisplayItems;
        if (items.Count == 0)
        {
            return null;
        }

        ClampSelection(items.Count);
        return items[_selectedIndex];
    }

    void ClampSelection(int? count = null)
    {
        var itemCount = count ?? DisplayItems.Count;
        if (itemCount == 0)
        {
            _selectedIndex = 0;
            return;
        }

        _selectedIndex = Math.Clamp(_selectedIndex, 0, itemCount - 1);
    }

    void Run(CommandItem item)
    {
        Close();
        Nav.NavigateTo(item.Route);
    }

    void Close()
    {
        _query = "";
        _selectedIndex = 0;
        _loaded = false;
        State.CloseCommandPalette();
    }

    static string Rel(DateTimeOffset timestamp)
    {
        var span = DateTimeOffset.UtcNow - timestamp;
        return span.TotalHours < 1 ? $"{Math.Max(1, (int)span.TotalMinutes)}m" :
            span.TotalDays < 1 ? $"{(int)span.TotalHours}h" :
            $"{(int)span.TotalDays}d";
    }

    public void Dispose()
    {
        State.OnChange -= OnStateChanged;
        _ref?.Dispose();
    }

    string RowClass(int index) => index == _selectedIndex ? "cmdk__row is-selected" : "cmdk__row";

    sealed record CommandItem(string Group, string Label, string Meta, string ShortType, string Tone, string Route)
    {
        public string Search { get; } = $"{Group} {Label} {Meta} {ShortType}";

        public int Score(string query) => CommandPaletteSearch.Score(query, Label, Group, Meta, ShortType, Search);
    }
}
