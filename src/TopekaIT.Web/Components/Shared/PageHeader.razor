@* Reusable page header with breadcrumbs, title, subtitle, and optional action area. *@
@code {
    [Parameter] public IReadOnlyList<string> Crumbs { get; set; } = [];
    [Parameter, EditorRequired] public string Title { get; set; } = "";
    [Parameter] public string? Subtitle { get; set; }
    [Parameter] public RenderFragment? Actions { get; set; }
}

<header class="page-head refresh-page-head">
    <div>
        @if (Crumbs.Count > 0)
        {
            <div class="page-head__crumbs">
                @for (var i = 0; i < Crumbs.Count; i++)
                {
                    <span>@Crumbs[i]</span>
                    @if (i < Crumbs.Count - 1)
                    {
                        <span>/</span>
                    }
                }
            </div>
        }
        <div class="page-head__title-row">
            <h1>@Title</h1>
            @if (Actions != null)
            {
                <div class="page-head__actions">@Actions</div>
            }
        </div>
        @if (!string.IsNullOrWhiteSpace(Subtitle))
        {
            <div class="page-head__sub">@Subtitle</div>
        }
    </div>
</header>
