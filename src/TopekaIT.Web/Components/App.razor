@using TopekaIT.Web.Services

<!DOCTYPE html>
<html lang="en" data-theme="light">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <ResourcePreloader />
    <link rel="stylesheet" href="@Assets["app.css"]" />
    <link rel="stylesheet" href="@Assets["TopekaIT.Web.styles.css"]" />
    <link rel="stylesheet" href="_content/Blazor-ApexCharts/css/apexcharts.css" />
    <ImportMap />
    <link rel="icon" type="image/png" href="favicon.png" />
    <title>Local IT</title>
    <script>
        (function () {
            try {
                var t = localStorage.getItem("topeka-theme");
                if (t) document.documentElement.setAttribute("data-theme", t);
            } catch { }
        })();
    </script>
    <script src="@Assets["js/theme.js"]"></script>
    <HeadOutlet />
</head>

<body>
    <Routes />
    <ReconnectModal />
    <script src="@Assets["_framework/blazor.web.js"]"></script>
    <script src="_content/Blazor-ApexCharts/js/blazor-apexcharts.js"></script>
</body>

</html>
