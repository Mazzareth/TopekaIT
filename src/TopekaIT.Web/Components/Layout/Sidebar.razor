@* Permission-built navigation. Roles are the starting point, but the resolved access set decides what shows up. *@
@using System.Security.Claims
@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthProvider
@inject TicketService Tickets
@inject PrinterService Printers
@inject ITenantContext TenantContext
@inject AccessControlService Access
@implements IDisposable

<nav class="app-nav" aria-label="Primary">
    <div class="app-nav__primary">
        @foreach (var item in _primary)
        {
            @NavButton(item)
        }
    </div>
    @if (_secondary.Count > 0)
    {
        <div class="app-nav__secondary">
            <div class="nav-sep"></div>
            @foreach (var item in _secondary)
            {
                @NavButton(item)
            }
        </div>
    }
</nav>

@code {
    record NavItem(string Id, string Label, string Icon, string Route);

    List<NavItem> _primary = new();
    List<NavItem> _secondary = new();
    UserAccess? _access;
    AccessTier _tier = AccessTier.Worker;
    int _openTickets;
    int _downPrinters;

    RenderFragment NavButton(NavItem item) => @<button type="button"
        class="app-nav__item @(IsActive(item.Route) ? "is-active" : "")"
        @onclick="() => Go(item.Route)">
        <Icon Name="@item.Icon" Size="15" />
        <span>@item.Label</span>
        @if (Badge(item.Id) > 0)
        {
            <span class="badge @(item.Id == "printers" ? "urgent" : "")">@Badge(item.Id)</span>
        }
    </button>;

    protected override async Task OnInitializedAsync()
    {
        Nav.LocationChanged += LocationChanged;
        var auth = await AuthProvider.GetAuthenticationStateAsync();
        var userId = auth.User.FindFirst(ClaimTypes.NameIdentifier)?.Value ?? "";
        _access = await Access.GetUserAccessAsync(userId);
        _tier = _access?.Tier ?? AccessTierExtensions.ParseTierOrWorker(auth.User.FindFirst(ClaimTypes.Role)?.Value);
        BuildNav();
        await RefreshBadges();
    }

    void BuildNav()
    {
        // Build from permissions instead of hard-coded roles so access overrides immediately change the shell.
        _primary = new();
        _secondary = new();

        if (TenantContext.IsResolved)
        {
            AddPrinterNav();
            AddAssetNav();
            AddTicketNav();
            AddIf(_primary, AccessPermissionKeys.LockersView, "lockers", "Lockers", "Locker", "/manager/lockers");
            AddIf(_primary, AccessPermissionKeys.AssetsViewSupervisorConsole, "loaners", "Loaners", "Clock", "/manager/loaners");
            AddHomeNav();
        }
        else
        {
            AddIf(_secondary, AccessPermissionKeys.AdminCreateDivisions, "divisions", "Divisions", "Activity", "/admin/divisions/new");
        }

        AddIf(_secondary, AccessPermissionKeys.AdminViewLantronix, "lantronix", "Lantronix", "Link", "/admin/lantronix");
        AddUsersNav();
        AddIf(_secondary, AccessPermissionKeys.AdminView, "admin", "Admin", "User", "/admin");
    }

    void AddHomeNav()
    {
        if (Has(AccessPermissionKeys.ItDashboard))
        {
            _primary.Add(new("home", "Control room", "Home", "/it"));
        }
        else if (Has(AccessPermissionKeys.SupervisorHome))
        {
            _primary.Add(new("home", "Home", "Home", "/manager"));
        }
        else if (Has(AccessPermissionKeys.WorkerHome))
        {
            _primary.Add(new("home", "Home", "Home", "/worker"));
        }
    }

    void AddTicketNav()
    {
        if (Has(AccessPermissionKeys.TicketsViewQueue))
        {
            _primary.Add(new("tickets", "Tickets", "Ticket", "/it/tickets"));
        }
        else if (Has(AccessPermissionKeys.TicketsViewOwn))
        {
            _primary.Add(new("tickets", "My requests", "Ticket", _tier >= AccessTier.Supervisor ? "/manager/tickets" : "/worker/tickets"));
        }
    }

    void AddPrinterNav()
    {
        if (Has(AccessPermissionKeys.PrintersViewAdmin))
        {
            _primary.Add(new("printers", "Printers", "Printer", "/it/printers"));
        }
        else if (Has(AccessPermissionKeys.PrintersViewStatus))
        {
            _primary.Add(new("printers", "Printers", "Printer", _tier >= AccessTier.Supervisor ? "/manager/printers" : "/worker/printers"));
        }
    }

    void AddAssetNav()
    {
        if (Has(AccessPermissionKeys.AssetsViewItConsole))
        {
            _primary.Add(new("assets", "Assets", "Watch", "/it/assets"));
            _primary.Add(new("rma", "RMA Flow", "Flag", "/it/rma"));
        }
        else if (Has(AccessPermissionKeys.AssetsViewSupervisorConsole))
        {
            _primary.Add(new("assets", "Assets", "Watch", "/manager/assets"));
            _primary.Add(new("rma", "RMA Flow", "Flag", "/manager/rma"));
        }
        AddIf(_primary, AccessPermissionKeys.AssetsViewSupervisorConsole, "station", "Station", "Scan", StationRoute);
    }

    void AddUsersNav()
    {
        if (!Has(AccessPermissionKeys.UsersView))
        {
            return;
        }

        var route = _tier == AccessTier.SuperAdmin
            ? "/admin/users"
            : _tier >= AccessTier.Admin
                ? "/it/users"
                : "/manager/users";
        var label = _tier >= AccessTier.Admin || _tier == AccessTier.SuperAdmin ? "Users" : "Workers";
        AddIf(_secondary, AccessPermissionKeys.UsersView, "users", label, "Users", route);
    }

    void AddIf(List<NavItem> target, string permission, string id, string label, string icon, string route)
    {
        if (Has(permission) && target.All(item => item.Id != id))
        {
            target.Add(new(id, label, icon, route));
        }
    }

    bool Has(string permission) => _access?.Has(permission) == true;

    string StationRoute => TenantContext.IsResolved && !string.IsNullOrWhiteSpace(TenantContext.DivisionId)
        ? $"/station/equipment/{Uri.EscapeDataString(TenantContext.DivisionId)}"
        : "/station/equipment";

    async Task RefreshBadges()
    {
        if (!TenantContext.IsResolved)
        {
            _openTickets = 0;
            _downPrinters = 0;
            return;
        }

        var auth = await AuthProvider.GetAuthenticationStateAsync();
        var userId = auth.User.FindFirst(ClaimTypes.NameIdentifier)?.Value ?? "";

        var allTickets = await Tickets.GetAllAsync();
        _openTickets = Has(AccessPermissionKeys.TicketsViewQueue)
            ? allTickets.Count(t => t.Status != TicketStatus.Resolved)
            : allTickets.Count(t => t.ReportedById == userId && t.Status != TicketStatus.Resolved);

        var allPrinters = await Printers.GetAllAsync();
        _downPrinters = allPrinters.Count(p => p.Status == PrinterStatus.Down);
    }

    int Badge(string id) => id switch
    {
        "tickets" => _openTickets,
        "printers" => _downPrinters,
        _ => 0,
    };

    bool IsActive(string route)
    {
        var current = new Uri(Nav.Uri).AbsolutePath.TrimEnd('/');
        if (current.Length == 0) current = "/";
        var normalizedRoute = route.TrimEnd('/');
        if (normalizedRoute.Length == 0) normalizedRoute = "/";
        if (current == normalizedRoute) return true;
        var isRoleHome = normalizedRoute is "/worker" or "/manager" or "/it";
        return !isRoleHome && current.StartsWith(normalizedRoute, StringComparison.OrdinalIgnoreCase);
    }

    void Go(string route) => Nav.NavigateTo(route);

    async void LocationChanged(object? sender, LocationChangedEventArgs e)
    {
        await RefreshBadges();
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        Nav.LocationChanged -= LocationChanged;
    }
}
