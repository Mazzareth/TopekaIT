@* Main app shell. It resolves tenant context and password-change gates before showing the navigation frame. *@
@inherits LayoutComponentBase
@implements IDisposable
@inject AppState State
@inject AuthenticationStateProvider AuthProvider
@inject ITenantContext TenantContext
@inject IDivisionRepository DivisionRepo
@inject NavigationManager Nav
@inject AccessControlService Access
@inject UserService Users

@if (_ready)
{
    <div class="app refresh-shell">
        <TopBar />
        <Sidebar />
        <FleetPulse />
        <main class="main">
            @Body
        </main>
        <CommandPalette />
        <PrinterCommandPalette />
        <ToastContainer />
    </div>
}

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    bool _ready;

    protected override async Task OnInitializedAsync()
    {
        State.OnChange += Rerender;

        // The layout is the first reliable place to enforce this after login, before any tenant page starts loading data.
        var auth = await AuthProvider.GetAuthenticationStateAsync();
        var userId = auth.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "";
        var path = new Uri(Nav.Uri).AbsolutePath;
        if (!string.IsNullOrWhiteSpace(userId)
            && !path.StartsWith("/change-password", StringComparison.OrdinalIgnoreCase)
            && !path.StartsWith("/auth/logout", StringComparison.OrdinalIgnoreCase))
        {
            var currentUser = await Users.GetByIdAsync(userId);
            if (currentUser?.MustChangePassword == true)
            {
                Nav.NavigateTo("/change-password");
                return;
            }
        }

        var divisionId = auth.User.FindFirst("division")?.Value;
        if (string.IsNullOrWhiteSpace(divisionId))
        {
            divisionId = auth.User.FindFirst("active_division")?.Value;
        }
        if (string.IsNullOrWhiteSpace(divisionId))
        {
            divisionId = StationDivisionFromPath(path);
        }

        if (!string.IsNullOrWhiteSpace(divisionId))
        {
            var division = await DivisionRepo.GetByIdAsync(divisionId);
            if (division != null)
            {
                TenantContext.SetDivision(division.Id, division.ConnectionString);
            }
        }
        else
        {
            if (await Access.HasPermissionAsync(userId, AccessPermissionKeys.AdminView)
                && !path.StartsWith("/admin", StringComparison.OrdinalIgnoreCase))
            {
                Nav.NavigateTo("/admin");
            }
        }

        _ready = true;
    }

    void Rerender() => InvokeAsync(StateHasChanged);
    public void Dispose() => State.OnChange -= Rerender;

    static string? StationDivisionFromPath(string path)
    {
        const string prefix = "/station/equipment/";
        if (!path.StartsWith(prefix, StringComparison.OrdinalIgnoreCase))
        {
            return null;
        }

        var divisionId = path[prefix.Length..].Trim('/');
        return string.IsNullOrWhiteSpace(divisionId) ? null : Uri.UnescapeDataString(divisionId);
    }
}
