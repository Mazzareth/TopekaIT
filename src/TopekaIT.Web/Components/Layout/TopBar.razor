@using System.Security.Claims
@using TopekaIT.Core.Services
@inject AppState State
@inject IJSRuntime JS
@inject ITenantContext TenantContext
@inject TicketService Tickets
@inject PrinterService Printers

<div class="topbar">
    <div class="brand">
        <button class="iconbtn" @onclick="ToggleNav" title="Toggle nav">
            @if (State.NavCollapsed)
            {
                <Icon Name="ChevronRight" />
            }
            else
            {
                <Icon Name="ChevronLeft" />
            }
        </button>
        <div class="brand-mark">L</div>
        <div class="brand-text">Local IT</div>
    </div>
    <div class="topbar-search">
        <Icon Name="Search" Size="14" />
        <input placeholder="Search printers, assets, tickets…" />
        <span class="kbd">⌘K</span>
    </div>
    <div class="topbar-spacer"></div>
    <div class="topbar-right">
        <div class="system-pulse @PulseClass" title="@PulseTitle">
            <span class="dot"></span>
            <span>@PulseText</span>
            @if (TenantContext.IsResolved)
            {
                <span class="mono">@_openTickets/@_problemPrinters</span>
            }
        </div>
        <button class="iconbtn" title="Notifications"><Icon Name="Bell" /></button>
        <AuthorizeView>
            <Authorized>
                <div class="user-chip" title="@($"Signed in as {Name(context.User)}")" @onclick="ToggleProfileMenu">
                    <div class="avatar">@Avatar(context.User)</div>
                    <div>
                        <div class="u-name">@Name(context.User)</div>
                        <div class="u-role">@Role(context.User)</div>
                    </div>
                </div>
                @if (showProfileMenu)
                {
                    <div class="profile-dropdown">
                        <a href="/change-password" class="menu-item" @onclick="CloseProfileMenu">
                            <Icon Name="Key" /> Change my Password
                        </a>
                    </div>
                }
                <a class="iconbtn" href="/auth/logout" title="Sign out"><Icon Name="Logout" /></a>
            </Authorized>
        </AuthorizeView>
    </div>
</div>

@code {
    bool showProfileMenu = false;
    int _openTickets;
    int _problemPrinters;

    protected override async Task OnInitializedAsync()
    {
        if (!TenantContext.IsResolved)
        {
            return;
        }

        var tickets = await Tickets.GetAllAsync();
        _openTickets = tickets.Count(t => t.Status != TicketStatus.Resolved);

        var printers = await Printers.GetAllAsync();
        _problemPrinters = printers.Count(p => p.Status is PrinterStatus.Down or PrinterStatus.Warn);
    }

    void ToggleProfileMenu() => showProfileMenu = !showProfileMenu;
    void CloseProfileMenu() => showProfileMenu = false;

    string PulseClass => !TenantContext.IsResolved
        ? ""
        : _problemPrinters > 0 ? "down"
        : _openTickets > 8 ? "warn"
        : "";

    string PulseText => !TenantContext.IsResolved
        ? "No division"
        : _problemPrinters > 0 ? "Attention"
        : _openTickets > 8 ? "Busy"
        : "Systems normal";

    string PulseTitle => TenantContext.IsResolved
        ? $"{_openTickets} open tickets, {_problemPrinters} printers need attention"
        : "Select a division to see live system pulse";

    string Name(ClaimsPrincipal u) => u.FindFirst("name")?.Value ?? u.Identity?.Name ?? "";
    string Avatar(ClaimsPrincipal u) => u.FindFirst("avatar")?.Value ?? "?";
    string Role(ClaimsPrincipal u) => u.FindFirst(ClaimTypes.Role)?.Value ?? "";

    async Task ToggleNav()
    {
        State.ToggleNav();
        await JS.InvokeVoidAsync("topekaNav.toggle");
    }
}
