@page "/it/users"
@page "/manager/users"
@page "/admin/users"
@attribute [Authorize(Policy = AccessPermissionKeys.UsersView)]
@using System.Security.Claims
@using TopekaIT.Core.Services
@inject UserService UserService
@inject AppState State
@inject AuthenticationStateProvider AuthProvider
@inject DivisionService DivisionService
@inject IJSRuntime JS
@inject AccessControlService Access

<PageTitle>@PageTitleText · Topeka IT</PageTitle>

<div class="page">
    <div class="page-head">
        <div>
            <h1>@PageTitleText</h1>
            <div class="page-sub">Accounts, lockers, audit access, stale activity, and scoped feature access.</div>
        </div>
        <div class="page-actions">
            @if (_selected.Count > 0)
            {
                <button class="btn" @onclick="() => _selected.Clear()">@_selected.Count selected</button>
            }
            @if (_canCreateUsers)
            {
                <button class="btn btn-accent" @onclick="AddRow"><Icon Name="Plus" Size="14" /> Add user</button>
            }
        </div>
    </div>

    <div class="role-strip">
        @foreach (var item in RoleStats())
        {
            <div class="role-stat">
                <span class="mono">@item.Count</span>
                <span>@item.Label</span>
            </div>
        }
    </div>

    <div class="card">
        <div class="toolbar user-filter-toolbar">
            <label class="field user-search-field">
                <Icon Name="Search" Size="13" />
                <input @bind="_searchText" @bind:event="oninput" placeholder="Search name, username, position, locker" />
            </label>
            @if (CanSeeMultipleDivisions)
            {
                <label class="field">
                    <span class="lbl">Division</span>
                    <select @bind="_divisionFilter">
                        <option value="@AllDivisionsFilter">All divisions</option>
                        <option value="@GlobalDivisionFilter">Global</option>
                        @foreach (var division in _divisions.OrderBy(d => d.Name))
                        {
                            <option value="@division.Id">@division.Name</option>
                        }
                    </select>
                </label>
            }
        </div>

        @{
            var visibleRows = FilteredRows().ToList();
        }

        <div class="asset-table-head user-cols" style="@UserGridStyle">
            <label class="checkbox"><input type="checkbox" checked="@AllVisibleSelected" @onchange="ToggleAll" /></label>
            <div>Name</div>
            <div>Username</div>
            @if (_actorTier == AccessTier.SuperAdmin)
            {
                <div>Division</div>
            }
            <div>Position</div>
            <div>Locker</div>
            <div>Last active</div>
            <div>Audit</div>
            <div>Tier</div>
            <div style="text-align: right;">Actions</div>
        </div>

        @if (_rows.Count == 0)
        {
            <EmptyState IconName="Users" Title="@($"No {PageTitleText.ToLowerInvariant()} yet")">Add an account to get started.</EmptyState>
        }
        else if (visibleRows.Count == 0)
        {
            <EmptyState IconName="Users" Title="No matching users">Adjust the search or division filter.</EmptyState>
        }

        @foreach (var row in visibleRows)
        {
            @if (row.IsNew || row.IsEditing)
            {
                <div>
                    <div class="asset-row user-cols" style="@UserGridStyle">
                        <div></div>
                        <input class="inline-input" @bind="row.Name" @bind:event="oninput" placeholder="Full name" disabled="@(!CanEditRow(row))" />
                        <input class="inline-input mono" @bind="row.Username" @bind:event="oninput" placeholder="username" disabled="@(!CanEditRow(row))" />
                        @if (_actorTier == AccessTier.SuperAdmin)
                        {
                            <select class="inline-input" @bind="row.DivisionId" disabled="@(row.Role == AccessTier.SuperAdmin || !CanEditRow(row))">
                                <option value="">Global</option>
                                @foreach (var division in _divisions)
                                {
                                    <option value="@division.Id">@division.Name</option>
                                }
                            </select>
                        }
                        <input class="inline-input" @bind="row.Position" @bind:event="oninput" placeholder="Position" disabled="@(!CanEditRow(row))" />
                        <input class="inline-input mono" @bind="row.LockerNumber" @bind:event="oninput" placeholder="L#" disabled="@(!CanEditRow(row))" />
                        <div></div>
                        <label class="checkbox"><input type="checkbox" @bind="row.Audit" disabled="@(!CanEditRow(row))" /></label>
                        <select class="inline-input" @bind="row.Role" disabled="@(!CanChangeRowTier(row))">
                            @foreach (var tier in RoleOptions(row))
                            {
                                <option value="@tier">@tier.DisplayName()</option>
                            }
                        </select>
                        <div style="text-align: right; display: flex; gap: 6px; justify-content: flex-end;">
                            <button class="btn btn-sm btn-accent" @onclick="() => SaveRow(row)" disabled="@(string.IsNullOrWhiteSpace(row.Name) || string.IsNullOrWhiteSpace(row.Username) || !CanEditRow(row))">
                                <Icon Name="Check" Size="12" />
                            </button>
                            <button class="btn btn-sm btn-ghost" @onclick="() => CancelRow(row)"><Icon Name="X" Size="12" /></button>
                        </div>
                    </div>
                    @if (row.IsNew)
                    {
                        <div class="new-row-extra">
                            <label>Initial password</label>
                            <input type="password" class="inline-input" @bind="row.Password" @bind:event="oninput" placeholder="Leave blank for no password" />
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="asset-row user-cols user-signal-row @UserRowClass(row)" style="@UserGridStyle">
                    <label class="checkbox"><input type="checkbox" checked="@_selected.Contains(row.Id)" @onchange="args => ToggleSelected(row.Id, args)" /></label>
                    <div style="font-weight: 500;">@row.Name</div>
                    <div class="mono" style="font-size: 12px;">@row.Username</div>
                    @if (_actorTier == AccessTier.SuperAdmin)
                    {
                        <div style="font-size: 12px;">@DivisionName(row.DivisionId)</div>
                    }
                    <div style="font-size: 12px;">@row.Position</div>
                    <div class="mono" style="font-size: 12px;">@LockerText(row)</div>
                    <div class="mono" style="font-size: 11px; color: var(--text-faint);">@LastActiveText(row.LastActiveAt)</div>
                    <div style="font-size: 12px;">@(row.Audit ? "Yes" : "No")</div>
                    <div><Pill Kind="@RolePill(row.Role)">@row.Role.DisplayName()</Pill></div>
                    <div style="text-align: right; display: flex; gap: 6px; justify-content: flex-end;">
                        @if (_canResetPasswords && CanManageRow(row))
                        {
                            <button class="btn btn-sm" @onclick="() => ResetPassword(row)" title="Reset password"><Icon Name="Key" Size="12" /></button>
                            <button class="btn btn-sm" @onclick="() => OpenStationPin(row)" title="Set station PIN">
                                <span class="mono">PIN</span>
                            </button>
                        }
                        @if (_canEditAccess && CanManageRow(row))
                        {
                            <button class="btn btn-sm" @onclick="() => OpenAccessCatalog(row)" title="Access catalog"><Icon Name="List" Size="12" /></button>
                        }
                        @if (_canEditUsers && CanManageRow(row))
                        {
                            <button class="btn btn-sm" @onclick="() => EditRow(row)"><Icon Name="Edit" Size="12" /></button>
                        }
                        @if (_canDeleteUsers && CanManageRow(row))
                        {
                            <button class="btn btn-sm btn-danger" @onclick="() => Remove(row)"><Icon Name="Trash" Size="12" /></button>
                        }
                    </div>
                </div>
            }
        }
        <div class="table-footer-integrity">
            <span>@visibleRows.Count of @_rows.Count users shown</span>
            <span>@visibleRows.Count(r => string.IsNullOrWhiteSpace(r.LockerNumber)) without locker</span>
            <span>@visibleRows.Count(r => r.LastActiveAt == null) never active</span>
        </div>
    </div>
</div>

<Modal Open="@_accessOpen" OnClose="CloseAccessCatalog" Wide>
    <Title>Access Catalog</Title>
    <ChildContent>
        @if (_accessRow != null && _selectedAccess != null)
        {
            <div style="display: grid; gap: 14px;">
                <div style="display: flex; justify-content: space-between; gap: 12px; align-items: center;">
                    <div>
                        <div style="font-weight: 600;">@_accessRow.Name</div>
                        <div style="font-size: 12px; color: var(--text-faint);">@_accessRow.Role.DisplayName() · @DivisionName(_accessRow.DivisionId)</div>
                    </div>
                    <div style="font-size: 12px; color: var(--text-faint);">Inherited defaults plus user overrides</div>
                </div>

                <div style="display: grid; gap: 10px;">
                    <input class="inline-input"
                           style="width: 100%;"
                           @bind="_accessSearch"
                           @bind:event="oninput"
                           placeholder="Search permissions by name, key, category, or tier" />
                    <div class="tab-row" style="overflow-x: auto; padding-bottom: 0;">
                        @foreach (var category in AccessCategoryOptions())
                        {
                            <button class="tab @AccessCategoryTabClass(category)" @onclick="() => _accessCategory = category">
                                @category
                                <span class="mono" style="font-size: 11px; color: var(--text-faint); margin-left: 4px;">@AccessCategoryCount(category)</span>
                            </button>
                        }
                    </div>
                </div>

                @{
                    var filteredPermissions = FilteredAccessPermissions().ToList();
                }

                @if (filteredPermissions.Count == 0)
                {
                    <EmptyState IconName="Search" Title="No permissions found">Adjust the search or category.</EmptyState>
                }

                @foreach (var categoryGroup in filteredPermissions.GroupBy(p => p.Group))
                {
                    <div class="card" style="padding: 0;">
                        <div class="card-head">
                            <span class="card-title">@categoryGroup.Key</span>
                            <span class="mono" style="font-size: 11px; color: var(--text-faint);">@categoryGroup.Count() permissions</span>
                        </div>
                        @foreach (var tierGroup in categoryGroup.GroupBy(p => p.DefaultTier).OrderBy(g => g.Key))
                        {
                            <div style="padding: 10px 14px 4px; display: flex; align-items: center; justify-content: space-between; gap: 10px; border-top: 1px solid var(--border-subtle);">
                                <div style="font-size: 12px; font-weight: 600; color: var(--text-dim);">@tierGroup.Key.DisplayName() defaults</div>
                                <div class="mono" style="font-size: 11px; color: var(--text-faint);">@tierGroup.Count() shown</div>
                            </div>
                            @foreach (var permission in tierGroup)
                            {
                                var isDefault = IsDefaultAllowed(_accessRow.Role, permission);
                                var isEffective = _selectedAccess.Has(permission.Key);
                                var overrideState = _selectedAccess.OverrideFor(permission.Key);
                                var canMutate = CanMutatePermission(_accessRow, permission);
                                <div class="asset-row" style="grid-template-columns: minmax(220px, 1.5fr) 90px 95px 120px 210px; align-items: center;">
                                    <div>
                                        <div style="font-weight: 500;">@permission.DisplayName</div>
                                        <div class="mono" style="font-size: 11px; color: var(--text-faint);">@permission.Key</div>
                                    </div>
                                    <div><Pill Kind="@(isDefault ? "pill-info" : "pill-dim")">@(isDefault ? "Default" : "Off")</Pill></div>
                                    <div><Pill Kind="@(isEffective ? "pill-up" : "pill-dim")">@(isEffective ? "Allowed" : "Denied")</Pill></div>
                                    <div><Pill Kind="pill-dim">@permission.GrantableTier.DisplayName()</Pill></div>
                                    <div style="display: flex; justify-content: flex-end; gap: 6px;">
                                        <button class="@OverrideButtonClass(overrideState == null)" disabled="@(!canMutate)" @onclick="() => SetPermissionOverride(permission.Key, null)">Inherit</button>
                                        <button class="@OverrideButtonClass(overrideState == PermissionOverrideState.Allow)" disabled="@(!canMutate)" @onclick="() => SetPermissionOverride(permission.Key, PermissionOverrideState.Allow)">Allow</button>
                                        <button class="@OverrideButtonClass(overrideState == PermissionOverrideState.Deny)" disabled="@(!canMutate)" @onclick="() => SetPermissionOverride(permission.Key, PermissionOverrideState.Deny)">Deny</button>
                                    </div>
                                </div>
                            }
                        }
                    </div>
                }
            </div>
        }
    </ChildContent>
    <Footer>
        <button class="btn btn-accent" @onclick="CloseAccessCatalog"><Icon Name="Check" Size="14" /> Done</button>
    </Footer>
</Modal>

<Modal Open="@_showSetPassword" OnClose="CloseSetPasswordModal">
    <Title>Set Password</Title>
    <ChildContent>
        <p style="margin-top: 0; color: var(--text-dim); font-size: 0.9rem;">
            Set a new password for <strong>@_pendingResetRow?.Name</strong>.
        </p>
        <div style="margin-top: 12px;">
            <label style="font-size: 0.8rem; color: var(--text-dim); display: block; margin-bottom: 6px;">New Password</label>
            <div style="display: flex; gap: 8px; align-items: center;">
                <input class="inline-input mono" type="text" style="flex: 1;"
                       placeholder="Leave blank to auto-generate"
                       @bind="_setPasswordInput" @bind:event="oninput" />
                <button class="btn btn-sm" @onclick="GeneratePasswordPreview" title="Generate password">
                    <Icon Name="RefreshCw" Size="14" />
                </button>
            </div>
        </div>
    </ChildContent>
    <Footer>
        <button class="btn" @onclick="CloseSetPasswordModal">Cancel</button>
        <button class="btn btn-accent" @onclick="ConfirmSetPassword">
            <Icon Name="Key" Size="14" /> Set Password
        </button>
    </Footer>
</Modal>

<Modal Open="@_showTempPassword" OnClose="CloseTempPasswordModal">
    <Title>Temporary Password</Title>
    <ChildContent>
        <p style="margin-top: 0; color: var(--text-dim); font-size: 0.9rem;">
            Password set for <strong>@_resetUserName</strong>.
        </p>
        <p style="margin-bottom: 8px; font-size: 0.85rem; color: var(--text-dim);">
            Share this password with the user. They should change it after logging in.
        </p>
        <div style="display: flex; align-items: center; gap: 8px; padding: 12px; background: var(--bg-sunken); border: 1px solid var(--border); border-radius: var(--radius); margin-top: 8px;">
            <code class="mono" style="flex: 1; font-weight: 600; user-select: all;">@_tempPassword</code>
            <button class="btn btn-sm btn-accent" @onclick="CopyTempPassword" title="Copy to clipboard">
                <Icon Name="@(string.IsNullOrEmpty(_copyFeedback) ? "Copy" : "Check")" Size="14" />
            </button>
        </div>
        @if (!string.IsNullOrEmpty(_copyFeedback))
        {
            <div style="color: var(--up); font-size: 0.8rem; margin-top: 6px;">@_copyFeedback</div>
        }
    </ChildContent>
    <Footer>
        <button class="btn btn-accent" @onclick="CloseTempPasswordModal"><Icon Name="Check" Size="14" /> Done</button>
    </Footer>
</Modal>

<Modal Open="@_showStationPin" OnClose="CloseStationPinModal">
    <Title>Station PIN</Title>
    <ChildContent>
        <p style="margin-top: 0; color: var(--text-dim); font-size: 0.9rem;">
            Set or clear the 6-digit station PIN for <strong>@_stationPinRow?.Name</strong>.
        </p>
        <div class="form-row">
            <label>PIN</label>
            <input class="inline-input mono"
                   inputmode="numeric"
                   maxlength="6"
                   autocomplete="off"
                   @bind="_stationPinInput"
                   @bind:event="oninput"
                   placeholder="@StationPinPlaceholder" />
        </div>
        @if (!string.IsNullOrWhiteSpace(_stationPinError))
        {
            <div class="form-error">@_stationPinError</div>
        }
    </ChildContent>
    <Footer>
        @if (_stationPinRow?.HasStationPin == true)
        {
            <button class="btn" @onclick="ClearStationPin">
                <Icon Name="X" Size="14" /> Clear PIN
            </button>
        }
        <button class="btn" @onclick="CloseStationPinModal">Cancel</button>
        <button class="btn btn-accent" @onclick="ConfirmStationPin">
            <Icon Name="Key" Size="14" /> Save PIN
        </button>
    </Footer>
</Modal>

@code {
    List<UserRow> _rows = new();
    List<Division> _divisions = new();
    HashSet<string> _selected = new();
    AccessTier _actorTier = AccessTier.Worker;
    string _currentUserId = "";
    string? _currentDivisionId;
    string _searchText = "";
    string _divisionFilter = AllDivisionsFilter;

    bool _canCreateUsers;
    bool _canEditUsers;
    bool _canDeleteUsers;
    bool _canResetPasswords;
    bool _canChangeTier;
    bool _canEditAccess;

    bool _accessOpen;
    UserRow? _accessRow;
    UserAccess? _selectedAccess;
    const string AllAccessCategories = "All";
    string _accessCategory = AllAccessCategories;
    string _accessSearch = "";

    bool _showSetPassword;
    string _setPasswordInput = "";
    UserRow? _pendingResetRow;

    bool _showTempPassword;
    string _tempPassword = "";
    string _resetUserName = "";
    string _copyFeedback = "";

    bool _showStationPin;
    UserRow? _stationPinRow;
    string _stationPinInput = "";
    string _stationPinError = "";

    const string AllDivisionsFilter = "__all";
    const string GlobalDivisionFilter = "__global";

    string PageTitleText => _actorTier >= AccessTier.Admin || _actorTier == AccessTier.SuperAdmin ? "Users" : "Workers";
    string UserGridStyle => _actorTier == AccessTier.SuperAdmin
        ? "grid-template-columns: 40px 1fr 1fr 120px 100px 90px 105px 70px 100px 210px;"
        : "grid-template-columns: 40px 1fr 1fr 100px 90px 105px 70px 100px 210px;";
    string StationPinPlaceholder => _stationPinRow?.HasStationPin == true ? "PIN already set" : "6 digits";
    bool CanSeeMultipleDivisions => _actorTier == AccessTier.SuperAdmin;
    bool AllVisibleSelected
    {
        get
        {
            var selectableRows = FilteredRows().Where(r => !r.IsNew && !r.IsEditing).ToList();
            return selectableRows.Count > 0 && selectableRows.All(r => _selected.Contains(r.Id));
        }
    }

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthProvider.GetAuthenticationStateAsync();
        _currentUserId = auth.User.FindFirst(ClaimTypes.NameIdentifier)?.Value ?? "";
        _currentDivisionId = auth.User.FindFirst("division")?.Value;
        if (string.IsNullOrWhiteSpace(_currentDivisionId))
        {
            _currentDivisionId = auth.User.FindFirst("active_division")?.Value;
        }

        var currentAccess = await Access.GetUserAccessAsync(_currentUserId);
        _actorTier = currentAccess?.Tier ?? AccessTierExtensions.ParseTierOrWorker(auth.User.FindFirst(ClaimTypes.Role)?.Value);
        _canCreateUsers = currentAccess?.Has(AccessPermissionKeys.UsersCreate) == true;
        _canEditUsers = currentAccess?.Has(AccessPermissionKeys.UsersEdit) == true;
        _canDeleteUsers = currentAccess?.Has(AccessPermissionKeys.UsersDelete) == true;
        _canResetPasswords = currentAccess?.Has(AccessPermissionKeys.UsersResetPasswords) == true;
        _canChangeTier = currentAccess?.Has(AccessPermissionKeys.UsersChangeTier) == true;
        _canEditAccess = currentAccess?.Has(AccessPermissionKeys.UsersEditAccess) == true;

        _divisions = (await DivisionService.GetAllAsync()).ToList();
        await Load();
    }

    async Task Load()
    {
        var unsavedNewRows = _rows.Where(r => r.IsNew).ToList();
        IEnumerable<User> allUsers = await UserService.GetAllAsync();
        if (_actorTier == AccessTier.SuperAdmin)
        {
        }
        else if (_actorTier >= AccessTier.Admin)
        {
            allUsers = allUsers.Where(u => u.DivisionId == _currentDivisionId);
        }
        else
        {
            allUsers = allUsers.Where(u => u.DivisionId == _currentDivisionId && u.Role == AccessTier.Worker);
        }

        _rows = allUsers.OrderBy(u => u.Name).Select(u => new UserRow
        {
            Id = u.Id,
            Name = u.Name,
            Username = u.Username,
            Role = u.Role,
            Avatar = u.Avatar,
            Position = u.Position,
            LockerNumber = u.LockerNumber,
            Audit = u.Audit,
            DivisionId = u.DivisionId,
            LastActiveAt = u.LastActiveAt,
            HasStationPin = !string.IsNullOrWhiteSpace(u.StationPinHash),
        }).ToList();

        foreach (var unsaved in unsavedNewRows)
        {
            _rows.Insert(0, unsaved);
        }
    }

    IEnumerable<RoleStat> RoleStats()
        => Enum.GetValues<AccessTier>()
            .Select(role => new RoleStat(role.DisplayName(), _rows.Count(r => r.Role == role)))
            .Where(stat => stat.Count > 0);

    void ToggleAll(ChangeEventArgs args)
    {
        var isChecked = args.Value is bool b && b;
        var visibleIds = FilteredRows()
            .Where(r => !r.IsNew && !r.IsEditing)
            .Select(r => r.Id)
            .ToHashSet(StringComparer.OrdinalIgnoreCase);

        if (!isChecked)
        {
            _selected.RemoveWhere(visibleIds.Contains);
            return;
        }

        foreach (var id in visibleIds)
        {
            _selected.Add(id);
        }
    }

    void ToggleSelected(string id, ChangeEventArgs args)
    {
        var isChecked = args.Value is bool b && b;
        if (isChecked) _selected.Add(id);
        else _selected.Remove(id);
    }

    void AddRow()
    {
        if (!_canCreateUsers) return;
        var divisionId = CanSeeMultipleDivisions && _divisionFilter != AllDivisionsFilter && _divisionFilter != GlobalDivisionFilter
            ? _divisionFilter
            : _currentDivisionId;
        _rows.Insert(0, new UserRow { IsNew = true, Role = AccessTier.Worker, DivisionId = divisionId });
    }

    void EditRow(UserRow row)
    {
        if (!CanEditRow(row)) return;
        row.IsEditing = true;
        row._backupName = row.Name;
        row._backupUsername = row.Username;
        row._backupRole = row.Role;
        row._backupDivisionId = row.DivisionId;
        row._backupPosition = row.Position;
        row._backupLockerNumber = row.LockerNumber;
        row._backupAudit = row.Audit;
    }

    void CancelRow(UserRow row)
    {
        if (row.IsNew)
        {
            _rows.Remove(row);
            return;
        }

        row.Name = row._backupName;
        row.Username = row._backupUsername;
        row.Role = row._backupRole;
        row.DivisionId = row._backupDivisionId;
        row.Position = row._backupPosition;
        row.LockerNumber = row._backupLockerNumber;
        row.Audit = row._backupAudit;
        row.IsEditing = false;
    }

    async Task SaveRow(UserRow row)
    {
        if (string.IsNullOrWhiteSpace(row.Name) || string.IsNullOrWhiteSpace(row.Username)) return;
        if (!CanEditRow(row)) return;

        if (!CanAssignTier(row.Role))
        {
            State.PushToast("You can only assign lower tiers.", "down");
            return;
        }

        if (!row.IsNew && row.Role != row._backupRole && !_canChangeTier)
        {
            State.PushToast("You do not have access to change tiers.", "down");
            return;
        }

        var divisionId = row.Role == AccessTier.SuperAdmin
            ? null
            : (_actorTier == AccessTier.SuperAdmin ? row.DivisionId : _currentDivisionId);

        if (row.Role != AccessTier.SuperAdmin && string.IsNullOrWhiteSpace(divisionId))
        {
            State.PushToast("Select a division.", "down");
            return;
        }

        if (row.IsNew)
        {
            var created = await UserService.CreateAsync(row.Name.Trim(), row.Username.Trim(), row.Password, row.Role, divisionId);
            created.Position = row.Position;
            created.LockerNumber = row.LockerNumber;
            created.Audit = row.Audit;
            await UserService.UpdateAsync(created, null);
            State.PushToast($"Added {created.Name}", "up");
            _rows.Remove(row);
        }
        else
        {
            var existing = (await UserService.GetAllAsync()).FirstOrDefault(u => u.Id == row.Id);
            if (existing != null)
            {
                existing.Name = row.Name.Trim();
                existing.Username = row.Username.Trim();
                existing.Role = row.Role;
                existing.DivisionId = divisionId;
                existing.Position = row.Position;
                existing.LockerNumber = row.LockerNumber;
                existing.Audit = row.Audit;
                await UserService.UpdateAsync(existing, string.IsNullOrEmpty(row.Password) ? null : row.Password);
                State.PushToast($"Updated {existing.Name}", "");
            }
        }

        await Load();
    }

    async Task Remove(UserRow row)
    {
        if (!_canDeleteUsers || !CanManageRow(row)) return;
        var confirmed = await JS.InvokeAsync<bool>("confirm", $"Delete {row.Name}? This cannot be undone.");
        if (!confirmed) return;
        await UserService.DeleteAsync(row.Id);
        State.PushToast($"Removed {row.Name}", "");
        await Load();
    }

    async Task OpenAccessCatalog(UserRow row)
    {
        if (!_canEditAccess || !CanManageRow(row)) return;
        _accessRow = row;
        _selectedAccess = await Access.GetUserAccessAsync(row.Id);
        _accessCategory = AllAccessCategories;
        _accessSearch = "";
        _accessOpen = true;
    }

    async Task SetPermissionOverride(string permissionKey, PermissionOverrideState? state)
    {
        if (_accessRow == null) return;
        var result = await Access.SetOverrideAsync(_currentUserId, _accessRow.Id, permissionKey, state);
        if (!result.Succeeded)
        {
            State.PushToast(result.Error ?? "Access change denied.", "down");
            return;
        }

        _selectedAccess = await Access.GetUserAccessAsync(_accessRow.Id);
        State.PushToast("Access updated", "up");
    }

    void CloseAccessCatalog()
    {
        _accessOpen = false;
        _accessRow = null;
        _selectedAccess = null;
        _accessCategory = AllAccessCategories;
        _accessSearch = "";
    }

    void ResetPassword(UserRow row)
    {
        if (!_canResetPasswords || !CanManageRow(row)) return;
        _pendingResetRow = row;
        _setPasswordInput = "";
        _showSetPassword = true;
    }

    void CloseSetPasswordModal()
    {
        _showSetPassword = false;
        _setPasswordInput = "";
        _pendingResetRow = null;
    }

    void GeneratePasswordPreview() => _setPasswordInput = UserService.GenerateTempPassword();

    async Task ConfirmSetPassword()
    {
        if (_pendingResetRow == null) return;
        if (!_canResetPasswords || !CanManageRow(_pendingResetRow)) return;
        var row = _pendingResetRow;
        var custom = string.IsNullOrWhiteSpace(_setPasswordInput) ? null : _setPasswordInput;
        CloseSetPasswordModal();
        try
        {
            _tempPassword = await UserService.ResetPasswordAsync(row.Id, custom);
            _resetUserName = row.Name;
            _copyFeedback = "";
            _showTempPassword = true;
            State.PushToast($"Password set for {row.Name}", "up");
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"SetPassword error for {row.Id}: {ex}");
            State.PushToast("Failed to set password.", "down");
        }
    }

    async Task CopyTempPassword()
    {
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", _tempPassword);
        _copyFeedback = "Copied to clipboard!";
    }

    void CloseTempPasswordModal()
    {
        _showTempPassword = false;
        _tempPassword = "";
        _resetUserName = "";
        _copyFeedback = "";
    }

    void OpenStationPin(UserRow row)
    {
        if (!_canResetPasswords || !CanManageRow(row)) return;
        _stationPinRow = row;
        _stationPinInput = "";
        _stationPinError = "";
        _showStationPin = true;
    }

    void CloseStationPinModal()
    {
        _showStationPin = false;
        _stationPinRow = null;
        _stationPinInput = "";
        _stationPinError = "";
    }

    async Task ConfirmStationPin()
    {
        if (_stationPinRow == null) return;
        if (!_canResetPasswords || !CanManageRow(_stationPinRow)) return;

        var pin = _stationPinInput.Trim();
        if (pin.Length != 6 || !pin.All(char.IsDigit))
        {
            _stationPinError = "PIN must be exactly 6 numeric digits.";
            return;
        }

        try
        {
            await UserService.SetStationPinAsync(_stationPinRow.Id, pin);
            State.PushToast($"Station PIN set for {_stationPinRow.Name}", "up");
            CloseStationPinModal();
            await Load();
        }
        catch (Exception ex)
        {
            _stationPinError = ex.Message;
        }
    }

    async Task ClearStationPin()
    {
        if (_stationPinRow == null) return;
        if (!_canResetPasswords || !CanManageRow(_stationPinRow)) return;

        await UserService.ClearStationPinAsync(_stationPinRow.Id);
        State.PushToast($"Station PIN cleared for {_stationPinRow.Name}", "");
        CloseStationPinModal();
        await Load();
    }

    bool CanEditRow(UserRow row)
        => row.IsNew ? _canCreateUsers : _canEditUsers && CanManageRow(row);

    bool CanChangeRowTier(UserRow row)
        => CanEditRow(row) && (row.IsNew || _canChangeTier);

    bool CanManageRow(UserRow row)
        => row.Id != _currentUserId && AccessCatalog.CanManageTier(_actorTier, row.Role);

    bool CanAssignTier(AccessTier tier)
        => AccessControlService.CanAssignTier(_actorTier, tier);

    IEnumerable<AccessTier> RoleOptions(UserRow row)
    {
        var options = Enum.GetValues<AccessTier>()
            .Where(CanAssignTier)
            .ToList();

        if (!options.Contains(row.Role))
        {
            options.Insert(0, row.Role);
        }

        return options.OrderBy(t => t);
    }

    bool CanMutatePermission(UserRow row, AccessPermissionDefinition permission)
        => _canEditAccess
            && CanManageRow(row)
            && AccessCatalog.IsPermissionGrantableBy(_actorTier, permission);

    static IEnumerable<string> AccessCategoryOptions()
        => new[] { AllAccessCategories }
            .Concat(AccessCatalog.Permissions.Select(p => p.Group).Distinct().OrderBy(group => group));

    int AccessCategoryCount(string category)
        => AccessCatalog.Permissions.Count(p => AccessCategoryMatches(p, category));

    string AccessCategoryTabClass(string category)
        => string.Equals(_accessCategory, category, StringComparison.OrdinalIgnoreCase) ? "active" : "";

    IEnumerable<AccessPermissionDefinition> FilteredAccessPermissions()
    {
        IEnumerable<AccessPermissionDefinition> permissions = AccessCatalog.Permissions
            .Where(p => AccessCategoryMatches(p, _accessCategory));

        if (!string.IsNullOrWhiteSpace(_accessSearch))
        {
            var search = _accessSearch.Trim();
            permissions = permissions.Where(p =>
                p.DisplayName.Contains(search, StringComparison.OrdinalIgnoreCase)
                || p.Key.Contains(search, StringComparison.OrdinalIgnoreCase)
                || p.Group.Contains(search, StringComparison.OrdinalIgnoreCase)
                || p.DefaultTier.DisplayName().Contains(search, StringComparison.OrdinalIgnoreCase)
                || p.GrantableTier.DisplayName().Contains(search, StringComparison.OrdinalIgnoreCase));
        }

        return permissions
            .OrderBy(p => p.Group)
            .ThenBy(p => p.DefaultTier)
            .ThenBy(p => p.DisplayName);
    }

    static bool AccessCategoryMatches(AccessPermissionDefinition permission, string category)
        => string.Equals(category, AllAccessCategories, StringComparison.OrdinalIgnoreCase)
            || string.Equals(permission.Group, category, StringComparison.OrdinalIgnoreCase);

    static bool IsDefaultAllowed(AccessTier tier, AccessPermissionDefinition permission)
        => tier == AccessTier.SuperAdmin || tier >= permission.DefaultTier;

    static string OverrideButtonClass(bool active)
        => active ? "btn btn-sm btn-primary" : "btn btn-sm";

    static string RolePill(AccessTier role) => role switch
    {
        AccessTier.Admin => "pill-info",
        AccessTier.SuperAdmin => "pill-info",
        AccessTier.Supervisor => "pill-warn",
        _ => "pill-dim",
    };

    static string LockerText(UserRow row) => string.IsNullOrWhiteSpace(row.LockerNumber) ? "No locker" : row.LockerNumber;

    static string LastActiveText(DateTimeOffset? lastActiveAt)
        => lastActiveAt.HasValue ? Format.RelTime(lastActiveAt.Value) : "Never";

    static string UserRowClass(UserRow row)
    {
        if (!row.LastActiveAt.HasValue) return "warn";
        return row.LastActiveAt.Value < DateTimeOffset.UtcNow.AddDays(-30) ? "warn" : "";
    }

    string DivisionName(string? divisionId)
    {
        if (string.IsNullOrWhiteSpace(divisionId)) return "Global";
        return _divisions.FirstOrDefault(d => d.Id == divisionId)?.Name ?? divisionId;
    }

    IEnumerable<UserRow> FilteredRows()
    {
        var rows = _rows.AsEnumerable();

        if (CanSeeMultipleDivisions)
        {
            rows = _divisionFilter switch
            {
                GlobalDivisionFilter => rows.Where(r => string.IsNullOrWhiteSpace(r.DivisionId)),
                AllDivisionsFilter => rows,
                _ => rows.Where(r => string.Equals(r.DivisionId, _divisionFilter, StringComparison.OrdinalIgnoreCase)),
            };
        }

        var search = _searchText.Trim();
        if (!string.IsNullOrWhiteSpace(search))
        {
            rows = rows.Where(r => MatchesSearch(r, search));
        }

        return rows;
    }

    bool MatchesSearch(UserRow row, string search)
        => Contains(row.Name, search)
            || Contains(row.Username, search)
            || Contains(row.Position, search)
            || Contains(row.LockerNumber, search)
            || Contains(row.Role.DisplayName(), search)
            || Contains(DivisionName(row.DivisionId), search);

    static bool Contains(string? value, string search)
        => !string.IsNullOrWhiteSpace(value)
            && value.Contains(search, StringComparison.OrdinalIgnoreCase);

    class UserRow
    {
        public string Id { get; set; } = "";
        public string Name { get; set; } = "";
        public string Username { get; set; } = "";
        public string Password { get; set; } = "";
        public string? DivisionId { get; set; }
        public string? Position { get; set; }
        public string? LockerNumber { get; set; }
        public DateTimeOffset? LastActiveAt { get; set; }
        public bool Audit { get; set; }
        public bool HasStationPin { get; set; }
        public AccessTier Role { get; set; }
        public string Avatar { get; set; } = "";
        public bool IsNew { get; set; }
        public bool IsEditing { get; set; }

        internal string _backupName = "";
        internal string _backupUsername = "";
        internal AccessTier _backupRole;
        internal string? _backupDivisionId;
        internal string? _backupPosition;
        internal string? _backupLockerNumber;
        internal bool _backupAudit;
    }

    record RoleStat(string Label, int Count);
}
