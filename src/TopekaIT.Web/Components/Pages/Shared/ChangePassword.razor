@* Required-password-change page. It keeps temporary credentials from becoming permanent by accident. *@
@page "/change-password"
@attribute [Authorize]
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@using TopekaIT.Core.Services
@using TopekaIT.Web.Services
@inject UserService Users
@inject AppState State
@inject NavigationManager Nav

<PageTitle>Change Password - Topeka IT</PageTitle>

<div class="page">
    <div class="page-head">
        <div>
            <h1 class="page-title">Change Password</h1>
            <div class="page-sub">@(_mustChangePassword ? "Set a new password before continuing." : "Update your account password.")</div>
        </div>
    </div>

    <div style="max-width: 420px;">
        <div class="card">
            <div class="panel-body">
                <form @onsubmit="Submit">
                    @if (!string.IsNullOrEmpty(error))
                    {
                        <div class="login-error">@error</div>
                    }
                    <div class="form-row">
                        <label>Current Password</label>
                        <input type="password" @bind="currentPassword" required />
                    </div>
                    <div class="form-row">
                        <label>New Password</label>
                        <input type="password" @bind="newPassword" required />
                    </div>
                    <div class="form-row">
                        <label>Confirm New Password</label>
                        <input type="password" @bind="confirmPassword" required />
                    </div>
                    <div style="display: flex; gap: 8px; justify-content: flex-end; margin-top: 8px;">
                        @if (!_mustChangePassword)
                        {
                            <button type="button" class="btn" @onclick="Cancel">Cancel</button>
                        }
                        <button type="submit" class="btn btn-primary" disabled="@_submitting">Update Password</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@code {
    [CascadingParameter] Task<AuthenticationState> AuthStateTask { get; set; } = default!;

    string currentPassword = "";
    string newPassword = "";
    string confirmPassword = "";
    string error = "";
    bool _submitting;
    bool _mustChangePassword;

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthStateTask;
        var id = state.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
        if (string.IsNullOrEmpty(id)) return;

        var dbUser = await Users.GetByIdAsync(id);
        _mustChangePassword = dbUser?.MustChangePassword == true;
    }

    async Task Submit()
    {
        error = "";
        if (newPassword != confirmPassword)
        {
            error = "New passwords do not match.";
            return;
        }

        _submitting = true;
        try
        {
            var state = await AuthStateTask;
            var user = state.User;
            var id = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;
            if (string.IsNullOrEmpty(id)) return;

            var dbUser = await Users.GetByIdAsync(id);
            if (dbUser == null) return;

            var validatedUser = await Users.ValidateCredentialsAsync(dbUser.Username, currentPassword);
            if (validatedUser == null)
            {
                error = "Current password is incorrect.";
                return;
            }

            await Users.UpdateAsync(dbUser, newPassword);
            State.PushToast("Password updated successfully.");
            Nav.NavigateTo("/", forceLoad: true);
        }
        finally
        {
            _submitting = false;
        }
    }

    void Cancel()
    {
        if (_mustChangePassword) return;
        Nav.NavigateTo("/");
    }
}
