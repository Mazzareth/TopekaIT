@page "/it/assets"
@attribute [Authorize(Policy = AccessPermissionKeys.AssetsViewItConsole)]
@using TopekaIT.Core.Domain.Entities
@using TopekaIT.Core.Domain.Enums
@using TopekaIT.Core.Services
@using TopekaIT.Web.Services
@inject AssetService AssetService
@inject UserService UserService
@inject AppState State
@inject AuthenticationStateProvider AuthProvider
@inject AccessControlService Access
@inject IJSRuntime JS

<PageTitle>Asset Console · Topeka IT</PageTitle>

<div class="page" style="max-width:none;">
    <div class="page-head">
        <div>
            <h1>Asset Console</h1>
            <div class="page-sub">Full asset inventory with raw flag control and inspector.</div>
        </div>
        <div class="page-actions">
            @if (_canCreateAssets)
            {
                <button class="btn" @onclick="() => _createOpen = true">
                    <Icon Name="Plus" Size="14" /> Add Asset
                </button>
            }
            @if (_canScanAssets)
            {
                <button class="btn" @onclick="() => _rfidScanOpen = true">
                    <Icon Name="Rfid" Size="14" /> RFID Scan
                </button>
                <button class="btn btn-primary" @onclick="() => _scanOpen = true">
                    <Icon Name="Scan" Size="14" /> Scan
                </button>
            }
        </div>
    </div>

    <div class="asset-kpi-strip">
        <div class="asset-kpi">
            <div class="kpi-n">Total SAE</div>
            <div class="kpi-v">@_assets.Count(a => a.Category == AssetCategory.SaeDevice)</div>
        </div>
        <div class="asset-kpi">
            <div class="kpi-n">TC77 PODs</div>
            <div class="kpi-v">@_assets.Count(a => a.Category == AssetCategory.PodTc77)</div>
        </div>
        <div class="asset-kpi kpi-info">
            <div class="kpi-n">With Holder</div>
            <div class="kpi-v">@_assets.Count(a => a.Flags.HasFlag(StatusFlags.WithHolder))</div>
            <div class="kpi-sub">+ @_assets.Count(a => a.Flags.HasFlag(StatusFlags.OnLoan)) loaned</div>
        </div>
        <div class="asset-kpi @(_attentionCount > 0 ? "kpi-warn" : "")">
            <div class="kpi-n">Attention</div>
            <div class="kpi-v">@_attentionCount</div>
            <div class="kpi-sub">RMA · Repair · Hold</div>
        </div>
        <div class="asset-kpi @(_assets.Any(a => a.Flags.HasFlag(StatusFlags.InRMA)) ? "kpi-down" : "")">
            <div class="kpi-n">In RMA</div>
            <div class="kpi-v">@_assets.Count(a => a.Flags.HasFlag(StatusFlags.InRMA))</div>
        </div>
        <div class="asset-kpi @(_assets.Any(a => a.Flags.HasFlag(StatusFlags.Missing)) ? "kpi-down" : "")">
            <div class="kpi-n">Missing</div>
            <div class="kpi-v">@_assets.Count(a => a.Flags.HasFlag(StatusFlags.Missing))</div>
        </div>
    </div>

    <div class="asset-workspace @(_selected != null ? "with-inspector" : "")">

        <div class="asset-filter-rail">
            <div>
                <div class="filter-rail-label">Search</div>
                <label class="field" style="width:100%;height:auto;padding:6px 8px;">
                    <Icon Name="Search" Size="13" />
                    <input @bind="_search" @bind:event="oninput" placeholder="Tag, S/N, holder…" style="width:100%;" />
                </label>
            </div>

            <div>
                <div class="filter-rail-label">Category</div>
                <label class="filter-check">
                    <input type="checkbox" @bind="_showSae" /> SAE Devices
                </label>
                <label class="filter-check">
                    <input type="checkbox" @bind="_showTc77" /> TC77 PODs
                </label>
                <label class="filter-check">
                    <input type="checkbox" @bind="_showScanner" /> Scanners
                </label>
                <label class="filter-check">
                    <input type="checkbox" @bind="_showBattery" /> Batteries
                </label>
            </div>

            <div>
                <div class="filter-rail-label">State</div>
                <label class="filter-check">
                    <input type="checkbox" @bind="_showAvailable" /> Available
                </label>
                <label class="filter-check">
                    <input type="checkbox" @bind="_showInUse" /> In Use / Loaned
                </label>
                <label class="filter-check">
                    <input type="checkbox" @bind="_showAttention" /> Attention
                </label>
            </div>

            <div style="margin-top:auto;padding-top:12px;border-top:1px solid var(--border);">
                <div class="filter-rail-label">Showing</div>
                <div style="font-size:13px;font-variant-numeric:tabular-nums;">
                    @Filtered().Count <span style="color:var(--text-faint)">/ @_assets.Count</span>
                </div>
            </div>
        </div>

        <div class="asset-table-body">
            <div class="asset-table-head table-cols">
                <div>Tag / S/N</div>
                <div>Cat</div>
                <div>Model</div>
                <div>RFID</div>
                <div>Holder</div>
                <div>State</div>
            </div>
            @if (!Filtered().Any())
            {
                <EmptyState IconName="Watch" Title="No results">Adjust the filters to find assets.</EmptyState>
            }
            else
            {
                @foreach (var a in Filtered())
                {
                    var holder = _users.FirstOrDefault(u => u.Id == a.HolderId);
                    var isSelected = _selected?.Id == a.Id;
                    <div class="asset-row asset-signal-row table-cols @Format.FlagRowCss(a.Flags) @(isSelected ? "active" : "")"
                         @onclick="() => Select(a)">
                        <div>
                            <div class="mono">@PrimaryTag(a)</div>
                            @if (!string.IsNullOrWhiteSpace(a.Serial) && a.Serial != PrimaryTag(a))
                            {
                                <span style="color:var(--text-faint);font-size:11px;">S/N @a.Serial</span>
                            }
                        </div>
                        <div style="color:var(--text-faint);font-size:12px;">@Format.CategoryLabel(a.Category)</div>
                        <div>
                            <div>@(string.IsNullOrWhiteSpace(a.Model) ? Format.CategoryLabel(a.Category) : a.Model)</div>
                        </div>
                        <div>
                            @if (!string.IsNullOrWhiteSpace(a.RfidTagId))
                            {
                                <span class="state-pill" style="font-size:10px;padding:1px 5px;">Linked</span>
                            }
                            else
                            {
                                <span style="color:var(--text-faint);font-size:12px;">—</span>
                            }
                        </div>
                        <div>
                            <div>@(holder?.Name ?? "—")</div>
                            @if (a.CheckedOutAt.HasValue)
                            {
                                <span style="color:var(--text-faint);font-size:11px;">@Format.RelTime(a.CheckedOutAt.Value)</span>
                            }
                        </div>
                        <div>
                            <span class="@Format.SimpleStateCss(a.Flags)">
                                <span class="dot"></span>@Format.SimpleState(a.Flags)
                            </span>
                        </div>
                    </div>
                }
            }
        </div>

        @if (_selected != null)
        {
            var sel = _selected;
            var selHolder = _users.FirstOrDefault(u => u.Id == sel.HolderId);
            var pairedSae = sel.PairedAssetId != null ? _assets.FirstOrDefault(a => a.Id == sel.PairedAssetId) : null;
            <div class="asset-inspector">
                <div class="inspector-head">
                    <div style="display:flex;align-items:center;gap:8px;">
                        <div class="inspector-id">@PrimaryTag(sel)</div>
                        <span class="@Format.SimpleStateCss(sel.Flags)" style="font-size:10px;padding:1px 6px;">
                            @Format.SimpleState(sel.Flags)
                        </span>
                    </div>
                    <div class="inspector-meta">@Format.CategoryLabel(sel.Category) · @(string.IsNullOrWhiteSpace(sel.Model) ? "No model" : sel.Model)</div>
                    <button class="iconbtn" style="position:absolute;top:10px;right:10px;" @onclick="() => _selected = null">
                        <Icon Name="X" Size="14" />
                    </button>
                </div>

                <div class="inspector-section">
                    <div class="inspector-label">Status Flags</div>
                    <div>
                        @foreach (var (flag, label, dotClass) in FlagDefs())
                        {
                            var isSet = sel.Flags.HasFlag(flag);
                            <div class="flag-toggle-row" @onclick="() => ToggleFlag(sel, flag)">
                                <span class="flag-dot @(isSet ? dotClass : "")"></span>
                                <span class="flag-label" style="@(isSet ? "color:var(--text);font-weight:500;" : "")">@label</span>
                                @if (isSet)
                                {
                                    <Icon Name="Check" Size="12" Style="color:var(--up);" />
                                }
                            </div>
                        }
                    </div>
                </div>

                @if (sel.IssueTags.Any(t => t.ResolvedAt == null))
                {
                    <div class="inspector-section">
                        <div class="inspector-label">Open Issues</div>
                        <div style="display:flex;flex-wrap:wrap;">
                            @foreach (var tag in sel.IssueTags.Where(t => t.ResolvedAt == null))
                            {
                                var sev = tag.Definition?.Severity ?? IssueSeverity.Info;
                                var chipClass = sev switch
                                {
                                    IssueSeverity.Critical => "issue-tag-chip sev-critical",
                                    IssueSeverity.Warning  => "issue-tag-chip sev-warning",
                                    _                      => "issue-tag-chip sev-info",
                                };
                                <span class="@chipClass">@(tag.Definition?.Label ?? tag.DefinitionCode)</span>
                            }
                        </div>
                    </div>
                }

                <div class="inspector-section">
                    <div class="inspector-label">Holder</div>
                    @if (selHolder != null)
                    {
                        <div style="font-weight:500;">@selHolder.Name</div>
                        @if (sel.CheckedOutAt.HasValue)
                        {
                            <div style="font-size:12px;color:var(--text-dim);">Since @Format.RelTime(sel.CheckedOutAt.Value)</div>
                        }
                    }
                    else
                    {
                        <div style="color:var(--text-faint);font-size:12px;">Unassigned</div>
                    }
                </div>

                @if (sel.Category == AssetCategory.SaeDevice)
                {
                    var paired = _assets.FirstOrDefault(a => a.PairedAssetId == sel.Id && a.Category == AssetCategory.Scanner);
                    <div class="inspector-section">
                        <div class="inspector-label">Paired Scanner</div>
                        @if (paired != null)
                        {
                            <div style="display:flex;align-items:center;gap:6px;">
                                <Icon Name="Scanner" Size="13" />
                                <span class="mono" style="font-size:12px;">@PrimaryTag(paired)</span>
                                <span style="color:var(--text-faint);font-size:11px;">@Format.ScannerKindLabel(paired.ScannerKind)</span>
                            </div>
                        }
                        else
                        {
                            <div style="color:var(--text-faint);font-size:12px;">No scanner paired</div>
                        }
                    </div>
                }

                @if (!string.IsNullOrWhiteSpace(sel.Notes))
                {
                    <div class="inspector-section">
                        <div class="inspector-label">Notes</div>
                        <div style="font-size:12px;color:var(--text-dim);white-space:pre-wrap;">@sel.Notes</div>
                    </div>
                }

                <div class="inspector-section" style="display:flex;flex-direction:column;gap:6px;">
                    <div class="inspector-label">Actions</div>
                    @if (sel.Flags.HasFlag(StatusFlags.InRMA))
                    {
                        <a href="/it/rma?search=@(sel.Tag ?? sel.Serial)" class="btn btn-sm btn-accent" style="text-decoration:none; display:flex; align-items:center; justify-content:center; gap:6px;">
                            <Icon Name="Flag" Size="12" /> Track RMA Timeline
                        </a>
                    }
                    <button class="btn btn-sm" @onclick="() => OpenDetail(sel, null)">
                        <Icon Name="Eye" Size="12" /> Full detail
                    </button>
                    <button class="btn btn-sm" @onclick='() => OpenDetail(sel, "rfid")'>
                        <Icon Name="Rfid" Size="12" /> RFID NTAG213
                    </button>
                    @if (!sel.Flags.HasFlag(StatusFlags.WithHolder))
                    {
                        <button class="btn btn-sm btn-primary" @onclick='() => OpenDetail(sel, "assign")'>
                            <Icon Name="User" Size="12" /> Assign holder
                        </button>
                    }
                    else
                    {
                        <button class="btn btn-sm" @onclick='() => OpenDetail(sel, "in")'>
                            <Icon Name="ArrowIn" Size="12" /> Check in
                        </button>
                    }
                    @if (_canDeleteAssets)
                    {
                        <button class="btn btn-sm btn-danger" @onclick="() => DeleteAsset(sel)">
                            <Icon Name="Trash" Size="12" /> Delete device
                        </button>
                    }
                </div>
            </div>
        }
    </div>
</div>

<ScanModal Open="_scanOpen" OnClose="() => _scanOpen = false" OnMatch="OnScanMatch" />
<RfidScanModal Open="_rfidScanOpen" OnClose="() => _rfidScanOpen = false" OnMatch="OnRfidScanMatch" />
<AssetDetail Asset="_viewing" Action="@_viewAction" Users="_users" OnClose="CloseDetail" OnChanged="Load" />
<AssetEditor Open="_createOpen" OnClose="() => _createOpen = false" OnChanged="Load" />

@code {
    bool _scanOpen;
    bool _rfidScanOpen;
    bool _createOpen;
    bool _canCreateAssets;
    bool _canDeleteAssets;
    bool _canScanAssets;
    bool _canUpdateFlags;
    bool _showSae      = true;
    bool _showTc77     = true;
    bool _showScanner  = true;
    // Batteries stay opt-in here so the IT console opens focused on serialized devices.
    bool _showBattery  = false;
    bool _showAvailable = true;
    bool _showInUse     = true;
    bool _showAttention = true;
    string _search = "";

    Asset? _selected;
    Asset? _viewing;
    string? _viewAction;

    List<Asset> _assets = new();
    List<User>  _users  = new();

    int _attentionCount => _assets.Count(a => Format.IsAttentionFlags(a.Flags));

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthProvider.GetAuthenticationStateAsync();
        var userId = auth.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "";
        var access = await Access.GetUserAccessAsync(userId);
        _canCreateAssets = access?.Has(AccessPermissionKeys.AssetsCreate) == true;
        _canDeleteAssets = access?.Has(AccessPermissionKeys.AssetsDelete) == true;
        _canScanAssets = access?.Has(AccessPermissionKeys.AssetsScanSearch) == true;
        _canUpdateFlags = access?.Has(AccessPermissionKeys.AssetsUpdateFlags) == true;
        await Load();
    }

    async Task Load()
    {
        _assets = (await AssetService.GetAllAsync()).ToList();
        _users  = (await UserService.GetAllAsync()).ToList();

        if (_selected != null)
            _selected = _assets.FirstOrDefault(a => a.Id == _selected.Id);
        if (_viewing != null)
            _viewing = _assets.FirstOrDefault(a => a.Id == _viewing.Id);
    }

    List<Asset> Filtered()
    {
        IEnumerable<Asset> q = _assets;

        q = q.Where(a => a.Category switch
        {
            AssetCategory.SaeDevice => _showSae,
            AssetCategory.PodTc77   => _showTc77,
            AssetCategory.Scanner   => _showScanner,
            AssetCategory.Battery   => _showBattery,
            _                       => true,
        });

        q = q.Where(a =>
        {
            var isAttention  = Format.IsAttentionFlags(a.Flags);
            var isInUse      = a.Flags.HasFlag(StatusFlags.WithHolder) || a.Flags.HasFlag(StatusFlags.OnLoan);
            var isAvailable  = !isInUse && !isAttention;
            return (isAttention && _showAttention) || (isInUse && _showInUse) || (isAvailable && _showAvailable);
        });

        if (!string.IsNullOrWhiteSpace(_search))
        {
            var s = _search.Trim();
            q = q.Where(a =>
            {
                var holder = _users.FirstOrDefault(u => u.Id == a.HolderId);
                return Contains(a.Tag, s) || Contains(a.Serial, s) || Contains(a.RfidTagId, s) || Contains(a.Model, s) || Contains(holder?.Name, s);
            });
        }

        return q
            .OrderByDescending(a => Format.IsAttentionFlags(a.Flags))
            .ThenByDescending(a => a.Flags.HasFlag(StatusFlags.WithHolder))
            .ThenBy(a => PrimaryTag(a))
            .ToList();
    }

    void Select(Asset a)
    {
        _selected = _selected?.Id == a.Id ? null : a;
    }

    void OpenDetail(Asset a, string? action)
    {
        _viewing    = a;
        _viewAction = action;
    }

    void CloseDetail()
    {
        _viewing    = null;
        _viewAction = null;
    }

    async Task OnScanMatch(Asset a)
    {
        _scanOpen = false;
        _selected = a;
        await Task.CompletedTask;
    }

    async Task OnRfidScanMatch(Asset a)
    {
        _rfidScanOpen = false;
        _selected = a;
        _viewing = a;
        _viewAction = null;
        await Task.CompletedTask;
    }

    async Task ToggleFlag(Asset a, StatusFlags flag)
    {
        var auth = await AuthProvider.GetAuthenticationStateAsync();
        if (!_canUpdateFlags) return;
        var actorId = auth.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "it";
        var actorName = auth.User.FindFirst(System.Security.Claims.ClaimTypes.Name)?.Value ?? "IT";

        var toSet   = a.Flags.HasFlag(flag) ? StatusFlags.None : flag;
        var toClear = a.Flags.HasFlag(flag) ? flag : StatusFlags.None;

        await AssetService.SetFlagsAsync(a.Id, toSet, toClear, actorName);
        await Load();
        State.PushToast($"Flag updated", "");
    }

    async Task DeleteAsset(Asset a)
    {
        if (!_canDeleteAssets) return;
        var label = PrimaryTag(a);
        var confirmed = await JS.InvokeAsync<bool>("confirm", $"Delete device {label}? This cannot be undone.");
        if (!confirmed) return;

        await AssetService.DeleteAsync(a.Id);
        State.PushToast($"Removed {label}", "");
        _selected = null;
        await Load();
    }

    static IEnumerable<(StatusFlags Flag, string Label, string DotClass)> FlagDefs() =>
    [
        (StatusFlags.InLocker,           "In Locker",           "f-active"),
        (StatusFlags.InCC,               "In CC / IT",          "f-active"),
        (StatusFlags.WithHolder,         "With Holder",         "f-info"),
        (StatusFlags.OnLoan,             "On Loan",             "f-info"),
        (StatusFlags.Spare,              "Spare Pool",          "f-active"),
        (StatusFlags.InRepair,           "In Repair",           "f-warn"),
        (StatusFlags.InRMA,              "In RMA",              "f-down"),
        (StatusFlags.Missing,            "Missing",             "f-down"),
        (StatusFlags.OnHold,             "On Hold",             "f-warn"),
        (StatusFlags.DayLoan,            "Day Loan",            "f-info"),
        (StatusFlags.UnderInvestigation, "Under Investigation", "f-warn"),
    ];

    static string PrimaryTag(Asset a) =>
        !string.IsNullOrWhiteSpace(a.Tag) ? a.Tag :
        !string.IsNullOrWhiteSpace(a.Serial) ? a.Serial : a.Id;

    static bool Contains(string? s, string v) =>
        !string.IsNullOrWhiteSpace(s) && s.Contains(v, StringComparison.OrdinalIgnoreCase);
}
