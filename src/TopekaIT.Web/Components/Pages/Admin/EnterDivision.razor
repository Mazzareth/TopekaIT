@* Blazor-friendly route that immediately hands division entry to the auth controller. Weird little bridge, but useful. *@
@page "/admin/enter/{DivisionId}"
@attribute [Authorize(Policy = AccessPermissionKeys.AdminEnterDivisions)]
@inject NavigationManager Nav

<PageTitle>Entering Division · Topeka IT</PageTitle>

@code {
    [Parameter] public string DivisionId { get; set; } = "";

    protected override void OnInitialized()
    {
        Nav.NavigateTo($"/auth/enter-division/{DivisionId}", forceLoad: true);
    }
}
