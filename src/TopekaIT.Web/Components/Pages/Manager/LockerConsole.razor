@page "/manager/lockers"
@attribute [Authorize(Policy = AccessPermissionKeys.LockersView)]
@using System.Security.Claims
@using TopekaIT.Core.Domain.Entities
@using TopekaIT.Core.Domain.Enums
@using TopekaIT.Core.Services
@inject LockerService LockerService
@inject UserService UserService
@inject AssetService AssetService
@inject AuthenticationStateProvider AuthProvider
@inject AccessControlService Access
@inject AppState State
@inject ITenantContext TenantContext

<PageTitle>Lockers - Topeka IT</PageTitle>

<div class="page">
    <div class="page-head">
        <div>
            <h1>Lockers</h1>
            <div class="page-sub">Division locker assignments.</div>
        </div>
        @if (_canEditLockers)
        {
            <div class="page-actions">
                <button class="btn btn-primary" @onclick="OpenCreateLocker">
                    <Icon Name="Plus" Size="14" /> Add Locker
                </button>
            </div>
        }
    </div>

    <div class="toolbar" style="padding-bottom: 8px;">
        <div class="seg">
            <button class="@(_lockerFilter == "all" ? "active" : "")" @onclick='() => _lockerFilter = "all"'>
                All <span class="count">@_lockers.Count</span>
            </button>
            <button class="@(_lockerFilter == "empty" ? "active" : "")" @onclick='() => _lockerFilter = "empty"'>
                Empty <span class="count">@_lockers.Count(IsEmptyLocker)</span>
            </button>
            <button class="@(_lockerFilter == "attention" ? "active" : "")" @onclick='() => _lockerFilter = "attention"'>
                Attention <span class="count">@_lockers.Count(LockerHasAttention)</span>
            </button>
        </div>
        <div class="spacer"></div>
        <label class="field">
            <Icon Name="Search" Size="13" />
            <input @bind="_lockerSearch" @bind:event="oninput" placeholder="Search locker, person, or device" />
        </label>
    </div>

    @if (_loadError != null)
    {
        <div class="form-error">@_loadError</div>
    }
    else if (!_lockers.Any())
    {
        <EmptyState IconName="Locker" Title="No lockers">
            @if (_canEditLockers)
            {
                <span>Create the first locker for this division.</span>
            }
            else
            {
                <span>No lockers have been created for this division.</span>
            }
        </EmptyState>
    }
    else
    {
        var filteredLockers = FilteredLockers();
        if (!filteredLockers.Any())
        {
            <EmptyState IconName="Locker" Title="No lockers">No lockers match the current view.</EmptyState>
        }
        else
        {
            <div class="locker-grid">
                @foreach (var locker in filteredLockers)
                {
                    var occupantUsers = ActiveOccupantUsers(locker).ToList();
                    var lockerAssets = AssetsInLocker(locker.Id).ToList();
                    var cardClass = LockerCardClass(lockerAssets);

                    <div class="locker-card @cardClass" @onclick="() => OpenLocker(locker)">
                        <div class="locker-head">
                            <span class="locker-num">#@locker.Number</span>
                            @if (!string.IsNullOrWhiteSpace(locker.Section))
                            {
                                <span class="locker-section-tag">@locker.Section</span>
                            }
                            @if (locker.IsShared || occupantUsers.Count > 1)
                            {
                                <span class="state-pill" style="font-size:10px;padding:1px 5px;">Shared</span>
                            }
                        </div>

                        <div class="locker-body">
                            <div class="locker-occupant">
                                @if (occupantUsers.Any())
                                {
                                    <span class="locker-occupant-name">@string.Join(", ", occupantUsers.Select(u => u.Name))</span>
                                }
                                else
                                {
                                    <span class="locker-unassigned">No assigned user</span>
                                }
                            </div>

                            <div class="locker-device-list">
                                @foreach (var asset in lockerAssets.Take(4))
                                {
                                    <div class="locker-device-row">
                                        <span class="device-tag">@PrimaryTag(asset)</span>
                                        <span class="@Format.SimpleStateCss(asset.Flags)">
                                            <span class="dot"></span>@Format.SimpleState(asset.Flags)
                                        </span>
                                    </div>
                                }
                                @if (lockerAssets.Count > 4)
                                {
                                    <div class="locker-empty-devices">@((lockerAssets.Count - 4).ToString()) more assigned</div>
                                }
                                else if (!lockerAssets.Any())
                                {
                                    <div class="locker-empty-devices">No devices assigned</div>
                                }
                            </div>
                        </div>

                        <div class="locker-foot">
                            <span class="locker-audit-ts">
                                @if (locker.LastAuditedAt.HasValue)
                                {
                                    <span>Audited @Format.RelTime(locker.LastAuditedAt.Value)</span>
                                }
                                else
                                {
                                    <span>Never audited</span>
                                }
                            </span>
                            <button class="btn btn-sm btn-ghost" @onclick:stopPropagation="true" @onclick="() => OpenLocker(locker)">
                                <Icon Name="Eye" Size="12" /> Open
                            </button>
                        </div>
                    </div>
                }
            </div>
        }
    }
</div>

<Modal Open="_createLockerOpen" OnClose="CloseCreateLocker">
    <Title>
        <span class="modal-title-icon">
            <Icon Name="Plus" Size="16" /> Add Locker
        </span>
    </Title>
    <ChildContent>
        <div class="form-row">
            <label>Locker #</label>
            <input class="mono" @bind="_newLockerNumber" @bind:event="oninput" @onkeydown="CreateLockerKey" autocomplete="off" />
        </div>
        @if (!string.IsNullOrWhiteSpace(_createLockerError))
        {
            <div class="form-error">@_createLockerError</div>
        }
    </ChildContent>
    <Footer>
        <button class="btn btn-ghost" @onclick="CloseCreateLocker" disabled="@_savingLocker">Cancel</button>
        <button class="btn btn-primary" @onclick="CreateLocker" disabled="@(_savingLocker || string.IsNullOrWhiteSpace(_newLockerNumber))">
            Create
        </button>
    </Footer>
</Modal>

<Modal Open="@(_selectedLocker != null)" OnClose="CloseLocker" Wide>
    <Title>
        <span class="modal-title-icon">
            <Icon Name="Locker" Size="16" /> Locker #@_selectedLocker?.Number
        </span>
    </Title>
    <ChildContent>
        @if (_selectedLocker != null)
        {
            var locker = _selectedLocker;
            var occupants = ActiveOccupants(locker).ToList();
            var users = ActiveOccupantUsers(locker).ToList();
            var assets = AssetsInLocker(locker.Id).ToList();

            <div style="display: grid; grid-template-columns: minmax(0, 1fr) minmax(0, 1fr); gap: 22px;">
                <div style="display: grid; gap: 18px;">
                    <section>
                        <h4 style="margin: 0 0 10px; font-size: 13px; text-transform: uppercase; color: var(--text-faint);">Locker</h4>
                        <div class="form-grid">
                            <div class="form-row">
                                <label>Locker #</label>
                                <input class="mono" @bind="locker.Number" @bind:event="oninput" disabled="@(!_canEditLockers)" />
                            </div>
                            <div class="form-row">
                                <label>Section</label>
                                <input @bind="locker.Section" @bind:event="oninput" disabled="@(!_canEditLockers)" />
                            </div>
                            <div class="form-row">
                                <label>Combo</label>
                                @if (_canEditLockers || (_canRevealCombos && _revealCombo))
                                {
                                    <input class="mono" @bind="locker.LockCombo" @bind:event="oninput" disabled="@(!_canEditLockers)" />
                                }
                                else if (_canRevealCombos)
                                {
                                    <button class="btn btn-sm" @onclick="() => _revealCombo = true">Reveal</button>
                                }
                                else
                                {
                                    <input value="Restricted" disabled />
                                }
                            </div>
                            <div class="form-row">
                                <label>Lock serial</label>
                                <input class="mono" @bind="locker.LockSerial" @bind:event="oninput" disabled="@(!_canEditLockers)" />
                            </div>
                        </div>
                        <div class="form-row">
                            <label>Notes</label>
                            <textarea @bind="locker.Notes" @bind:event="oninput" rows="2" disabled="@(!_canEditLockers)"></textarea>
                        </div>
                        <label class="checkbox" style="margin-top: 6px;">
                            <input type="checkbox" @bind="locker.IsShared" disabled="@(!_canEditLockers)" />
                            Shared locker
                        </label>
                        <div style="display: flex; gap: 8px; margin-top: 10px; flex-wrap: wrap;">
                            @if (_canEditLockers)
                            {
                                <button class="btn btn-primary" @onclick="SaveLocker" disabled="@_savingLocker">
                                    Save locker
                                </button>
                            }
                            @if (_canMarkAudits)
                            {
                                <button class="btn" @onclick="RecordAudit" disabled="@_savingLocker">
                                    <Icon Name="Check" Size="13" /> Mark audited
                                </button>
                            }
                        </div>
                        @if (!string.IsNullOrWhiteSpace(_lockerError))
                        {
                            <div class="form-error">@_lockerError</div>
                        }
                    </section>

                    <section>
                        <h4 style="margin: 0 0 10px; font-size: 13px; text-transform: uppercase; color: var(--text-faint);">Users</h4>
                        @if (users.Any())
                        {
                            <div class="locker-device-list" style="margin-bottom: 12px;">
                                @foreach (var occupant in occupants)
                                {
                                    var user = UserFor(occupant.UserId);
                                    <div class="locker-device-row">
                                        <span style="flex:1;">
                                            <strong>@(user?.Name ?? occupant.UserId)</strong>
                                            <span style="display:block;color:var(--text-faint);font-size:11px;">@(user?.Position ?? user?.Username ?? "Assigned user")</span>
                                        </span>
                                        @if (occupant.IsPrimary)
                                        {
                                            <span class="state-pill state-inuse">Primary</span>
                                        }
                                        @if (_canEditLockers && user != null)
                                        {
                                            <button class="btn btn-sm btn-ghost" @onclick="() => RemoveUserFromLocker(user)">
                                                <Icon Name="X" Size="12" />
                                            </button>
                                        }
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="locker-empty-devices" style="text-align:left;">No assigned users</div>
                        }

                        @if (_canAssignUsers)
                        {
                            <div class="form-row">
                                <label>Search user</label>
                                <input @bind="_userSearch" @bind:event="oninput" placeholder="Name or username" autocomplete="off" />
                            </div>
                            @if (UserSearchResults.Any())
                            {
                                <div class="locker-device-list" style="margin-bottom: 12px;">
                                    @foreach (var user in UserSearchResults)
                                    {
                                        <div class="locker-device-row">
                                            <span style="flex:1;">
                                                <strong>@user.Name</strong>
                                                <span style="display:block;color:var(--text-faint);font-size:11px;">@user.Username</span>
                                            </span>
                                            <button class="btn btn-sm btn-primary" @onclick="() => AssignUserToLocker(user)" disabled="@_savingUser">
                                                Add
                                            </button>
                                        </div>
                                    }
                                </div>
                            }

                            @if (_canCreateUsers)
                            {
                                <div class="form-grid">
                                    <div class="form-row">
                                        <label>Name</label>
                                        <input @bind="_newUserName" @bind:event="oninput" autocomplete="off" />
                                    </div>
                                    <div class="form-row">
                                        <label>Username</label>
                                        <input @bind="_newUsername" @bind:event="oninput" autocomplete="off" />
                                    </div>
                                </div>
                                <div class="form-row">
                                    <label>Position</label>
                                    <input @bind="_newUserPosition" @bind:event="oninput" autocomplete="off" />
                                </div>
                                <button class="btn" @onclick="CreateUserForLocker" disabled="@(_savingUser || string.IsNullOrWhiteSpace(_newUserName))">
                                    <Icon Name="User" Size="13" /> Create user
                                </button>
                            }
                            @if (!string.IsNullOrWhiteSpace(_createdUserPassword))
                            {
                                <div style="margin-top: 10px; padding: 10px; border: 1px solid var(--warn); background: var(--warn-bg); border-radius: 6px; font-size: 12px;">
                                    <div style="font-weight: 600; margin-bottom: 4px;">Temporary password for @_createdUserName</div>
                                    <code class="mono" style="user-select: all;">@_createdUserPassword</code>
                                </div>
                            }
                            @if (!string.IsNullOrWhiteSpace(_userError))
                            {
                                <div class="form-error">@_userError</div>
                            }
                        }
                    </section>
                </div>

                <div>
                    <h4 style="margin: 0 0 10px; font-size: 13px; text-transform: uppercase; color: var(--text-faint);">Devices</h4>
                    @if (assets.Any())
                    {
                        <div class="locker-device-list" style="margin-bottom: 14px;">
                            @foreach (var asset in assets)
                            {
                                var holder = UserFor(asset.HolderId);
                                <div class="locker-device-row">
                                    <span style="flex: 1; min-width: 0;">
                                        <strong class="mono">@PrimaryTag(asset)</strong>
                                        <span style="display:block;color:var(--text-faint);font-size:11px;">@DeviceSubtitle(asset, holder)</span>
                                    </span>
                                    <span class="@Format.SimpleStateCss(asset.Flags)">
                                        <span class="dot"></span>@Format.SimpleState(asset.Flags)
                                    </span>
                                    @if (_canAssignDevices)
                                    {
                                        <button class="btn btn-sm btn-ghost" @onclick="() => RemoveDeviceFromLocker(asset)">
                                            <Icon Name="X" Size="12" />
                                        </button>
                                    }
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="locker-empty-devices" style="text-align:left;">No assigned devices</div>
                    }

                    @if (_canAssignDevices)
                    {
                        <div class="form-row">
                            <label>Search device</label>
                            <div style="display: flex; gap: 8px;">
                                <input style="flex:1;" @bind="_deviceSearch" @bind:event="oninput" @onkeydown="DeviceSearchKey" placeholder="Serial, tag, IMEI, or ID" autocomplete="off" />
                                <button class="btn" @onclick="SearchDevice" disabled="@_savingDevice">
                                    <Icon Name="Search" Size="13" /> Search
                                </button>
                            </div>
                        </div>

                        @if (_deviceSearchResult != null)
                        {
                            <div class="locker-device-row" style="border: 1px solid var(--border); border-radius: 6px; padding: 8px; margin-bottom: 12px;">
                                <span style="flex:1;">
                                    <strong class="mono">@PrimaryTag(_deviceSearchResult)</strong>
                                    <span style="display:block;color:var(--text-faint);font-size:11px;">@_deviceSearchResult.Model</span>
                                </span>
                                <button class="btn btn-sm btn-primary" @onclick="() => AssignDeviceToLocker(_deviceSearchResult)" disabled="@_savingDevice">
                                    Assign
                                </button>
                            </div>
                        }
                        else if (_deviceSearchMissing)
                        {
                            <div class="form-grid">
                                <div class="form-row">
                                    <label>Serial number</label>
                                    <input class="mono" @bind="_newDeviceSerial" @bind:event="oninput" autocomplete="off" />
                                </div>
                                <div class="form-row">
                                    <label>Model</label>
                                    <input @bind="_newDeviceModel" @bind:event="oninput" autocomplete="off" />
                                </div>
                            </div>
                            <button class="btn" @onclick="CreateDeviceForLocker" disabled="@(_savingDevice || string.IsNullOrWhiteSpace(_newDeviceSerial) || string.IsNullOrWhiteSpace(_newDeviceModel))">
                                <Icon Name="Plus" Size="13" /> Create device
                            </button>
                        }

                        @if (!string.IsNullOrWhiteSpace(_deviceError))
                        {
                            <div class="form-error">@_deviceError</div>
                        }
                    }
                </div>
            </div>
        }
    </ChildContent>
    <Footer>
        <button class="btn btn-ghost" @onclick="CloseLocker">Close</button>
    </Footer>
</Modal>

@code {
    List<Locker> _lockers = new();
    List<Asset> _assets = new();
    List<User> _users = new();

    Locker? _selectedLocker;
    string _lockerSearch = "";
    string _lockerFilter = "all";
    string? _loadError;
    string? _lockerError;

    bool _createLockerOpen;
    string _newLockerNumber = "";
    string? _createLockerError;
    bool _savingLocker;

    string _deviceSearch = "";
    Asset? _deviceSearchResult;
    bool _deviceSearchMissing;
    string _newDeviceSerial = "";
    string _newDeviceModel = "";
    string? _deviceError;
    bool _savingDevice;

    string _userSearch = "";
    string _newUserName = "";
    string _newUsername = "";
    string _newUserPosition = "";
    string? _userError;
    string? _createdUserPassword;
    string? _createdUserName;
    bool _savingUser;

    bool _canEditLockers;
    bool _canRevealCombos;
    bool _canMarkAudits;
    bool _canCreateAssets;
    bool _canAssignAssets;
    bool _canCreateUsers;
    bool _canEditUsers;
    bool _revealCombo;

    string _actorId = "";
    string? _currentDivisionId;

    bool _canAssignDevices => _canEditLockers && _canAssignAssets;
    bool _canAssignUsers => _canEditLockers && _canEditUsers;

    IEnumerable<User> UserSearchResults
    {
        get
        {
            if (_selectedLocker == null || string.IsNullOrWhiteSpace(_userSearch))
            {
                return Enumerable.Empty<User>();
            }

            var activeUserIds = ActiveOccupants(_selectedLocker)
                .Select(o => o.UserId)
                .ToHashSet(StringComparer.OrdinalIgnoreCase);
            var s = _userSearch.Trim();

            return AssignableUsers()
                .Where(u => !activeUserIds.Contains(u.Id))
                .Where(u =>
                    Contains(u.Name, s) ||
                    Contains(u.Username, s) ||
                    Contains(u.Id, s))
                .OrderBy(u => u.Name)
                .Take(8);
        }
    }

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthProvider.GetAuthenticationStateAsync();
        _actorId = auth.User.FindFirst(ClaimTypes.NameIdentifier)?.Value ?? "";
        _currentDivisionId = auth.User.FindFirst("division")?.Value;
        if (string.IsNullOrWhiteSpace(_currentDivisionId))
        {
            _currentDivisionId = auth.User.FindFirst("active_division")?.Value;
        }
        if (string.IsNullOrWhiteSpace(_currentDivisionId))
        {
            _currentDivisionId = TenantContext.DivisionId;
        }

        var access = await Access.GetUserAccessAsync(_actorId);
        _canEditLockers = access?.Has(AccessPermissionKeys.LockersEditMetadata) == true;
        _canRevealCombos = access?.Has(AccessPermissionKeys.LockersRevealCombos) == true;
        _canMarkAudits = access?.Has(AccessPermissionKeys.LockersMarkAudits) == true;
        _canCreateAssets = access?.Has(AccessPermissionKeys.AssetsCreate) == true;
        _canAssignAssets = access?.Has(AccessPermissionKeys.AssetsAssign) == true;
        _canCreateUsers = access?.Has(AccessPermissionKeys.UsersCreate) == true;
        _canEditUsers = access?.Has(AccessPermissionKeys.UsersEdit) == true;

        await Load();
    }

    async Task Load()
    {
        try
        {
            var lockersTask = LockerService.GetAllAsync();
            var assetsTask = AssetService.GetAllAsync();
            var usersTask = UserService.GetAllAsync();
            await Task.WhenAll(lockersTask, assetsTask, usersTask);

            _lockers = (await lockersTask)
                .Where(l => l.IsActive)
                .OrderBy(l => LockerNumberValue(l.Number) ?? int.MaxValue)
                .ThenBy(l => l.Number)
                .ToList();
            _assets = (await assetsTask).ToList();
            _users = (await usersTask).ToList();
            _loadError = null;
        }
        catch (Exception ex)
        {
            _loadError = "Failed to load lockers: " + ex.Message;
        }
    }

    void OpenCreateLocker()
    {
        if (!_canEditLockers) return;
        _newLockerNumber = "";
        _createLockerError = null;
        _createLockerOpen = true;
    }

    void CloseCreateLocker()
    {
        _createLockerOpen = false;
        _createLockerError = null;
    }

    async Task CreateLockerKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await CreateLocker();
        }
    }

    async Task CreateLocker()
    {
        if (!_canEditLockers || string.IsNullOrWhiteSpace(_newLockerNumber)) return;

        _savingLocker = true;
        _createLockerError = null;
        try
        {
            var locker = new Locker { Number = _newLockerNumber.Trim() };
            await LockerService.AddAsync(locker);
            State.PushToast($"Locker {locker.Number} created", "up");
            _createLockerOpen = false;
            await Load();
            OpenLocker(_lockers.First(l => l.Id == locker.Id));
        }
        catch (Exception ex)
        {
            _createLockerError = ex.Message;
        }
        finally
        {
            _savingLocker = false;
        }
    }

    void OpenLocker(Locker locker)
    {
        _selectedLocker = locker;
        _lockerError = null;
        _revealCombo = false;
        ResetDeviceInputs();
        ResetUserInputs();
    }

    void CloseLocker()
    {
        _selectedLocker = null;
        _lockerError = null;
        ResetDeviceInputs();
        ResetUserInputs();
    }

    async Task SaveLocker()
    {
        if (_selectedLocker == null || !_canEditLockers) return;

        _savingLocker = true;
        _lockerError = null;
        try
        {
            await LockerService.UpdateAsync(_selectedLocker);
            await SyncLegacyLockerFields(_selectedLocker);
            await RefreshSelected(_selectedLocker.Id);
            State.PushToast($"Locker {_selectedLocker?.Number} saved", "up");
        }
        catch (Exception ex)
        {
            _lockerError = ex.Message;
        }
        finally
        {
            _savingLocker = false;
        }
    }

    async Task RecordAudit()
    {
        if (_selectedLocker == null || !_canMarkAudits) return;
        await LockerService.RecordAuditAsync(_selectedLocker.Id, _actorId);
        await RefreshSelected(_selectedLocker.Id);
        State.PushToast($"Locker {_selectedLocker?.Number} audited", "up");
    }

    async Task SearchDevice()
    {
        _deviceError = null;
        _deviceSearchResult = null;
        _deviceSearchMissing = false;

        var value = _deviceSearch.Trim();
        if (string.IsNullOrWhiteSpace(value)) return;

        _deviceSearchResult = await AssetService.FindByScanAsync(value);
        _deviceSearchMissing = _deviceSearchResult == null;
        if (_deviceSearchMissing)
        {
            _newDeviceSerial = value;
            _newDeviceModel = "";
        }
    }

    async Task DeviceSearchKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await SearchDevice();
        }
    }

    async Task AssignDeviceToLocker(Asset asset)
    {
        if (_selectedLocker == null || !_canAssignDevices) return;

        _savingDevice = true;
        _deviceError = null;
        try
        {
            await AssetService.AssignToLockerAsync(asset.Id, _selectedLocker.Id, _selectedLocker.Number, _actorId);
            State.PushToast($"{PrimaryTag(asset)} assigned to locker {_selectedLocker.Number}", "up");
            await RefreshSelected(_selectedLocker.Id);
            ResetDeviceInputs();
        }
        catch (Exception ex)
        {
            _deviceError = ex.Message;
        }
        finally
        {
            _savingDevice = false;
        }
    }

    async Task RemoveDeviceFromLocker(Asset asset)
    {
        if (_selectedLocker == null || !_canAssignDevices) return;

        _savingDevice = true;
        _deviceError = null;
        try
        {
            await AssetService.AssignToLockerAsync(asset.Id, null, null, _actorId);
            State.PushToast($"{PrimaryTag(asset)} removed from locker", "");
            await RefreshSelected(_selectedLocker.Id);
        }
        catch (Exception ex)
        {
            _deviceError = ex.Message;
        }
        finally
        {
            _savingDevice = false;
        }
    }

    async Task CreateDeviceForLocker()
    {
        if (_selectedLocker == null || !_canAssignDevices || !_canCreateAssets) return;
        if (string.IsNullOrWhiteSpace(_newDeviceSerial) || string.IsNullOrWhiteSpace(_newDeviceModel)) return;

        _savingDevice = true;
        _deviceError = null;
        try
        {
            var serial = _newDeviceSerial.Trim();
            var asset = new Asset
            {
                Id = Guid.NewGuid().ToString("N")[..16],
                Category = AssetCategory.SaeDevice,
                Type = "sae",
                Tag = serial,
                Serial = serial,
                Model = _newDeviceModel.Trim(),
                Quantity = 1,
                Status = AssetStatus.InLocker,
                Flags = StatusFlags.InLocker,
                LockerId = _selectedLocker.Id,
                LastSeenAt = DateTimeOffset.UtcNow,
                LastSeenLocation = _selectedLocker.Number,
            };

            await AssetService.AddAsync(asset);
            State.PushToast($"{serial} created in locker {_selectedLocker.Number}", "up");
            await RefreshSelected(_selectedLocker.Id);
            ResetDeviceInputs();
        }
        catch (Exception ex)
        {
            _deviceError = ex.Message;
        }
        finally
        {
            _savingDevice = false;
        }
    }

    async Task AssignUserToLocker(User user)
    {
        if (_selectedLocker == null || !_canAssignUsers) return;

        _savingUser = true;
        _userError = null;
        try
        {
            var isPrimary = !ActiveOccupants(_selectedLocker).Any();
            await LockerService.AssignOccupantAsync(_selectedLocker.Id, user.Id, isPrimary, _actorId);
            await UpdateUserLockerFields(user.Id, _selectedLocker);
            State.PushToast($"{user.Name} assigned to locker {_selectedLocker.Number}", "up");
            await RefreshSelected(_selectedLocker.Id);
            ResetUserInputs(keepCreatedPassword: true);
        }
        catch (Exception ex)
        {
            _userError = ex.Message;
        }
        finally
        {
            _savingUser = false;
        }
    }

    async Task RemoveUserFromLocker(User user)
    {
        if (_selectedLocker == null || !_canAssignUsers) return;

        _savingUser = true;
        _userError = null;
        try
        {
            await LockerService.UnassignOccupantAsync(_selectedLocker.Id, user.Id, _actorId);
            await ClearUserLockerFields(user.Id, _selectedLocker.Number);
            State.PushToast($"{user.Name} removed from locker {_selectedLocker.Number}", "");
            await RefreshSelected(_selectedLocker.Id);
        }
        catch (Exception ex)
        {
            _userError = ex.Message;
        }
        finally
        {
            _savingUser = false;
        }
    }

    async Task CreateUserForLocker()
    {
        if (_selectedLocker == null || !_canAssignUsers || !_canCreateUsers) return;
        if (string.IsNullOrWhiteSpace(_newUserName)) return;
        if (string.IsNullOrWhiteSpace(_currentDivisionId))
        {
            _userError = "Enter a division before creating a user.";
            return;
        }

        _savingUser = true;
        _userError = null;
        try
        {
            var username = string.IsNullOrWhiteSpace(_newUsername)
                ? UniqueUsername(_newUserName)
                : _newUsername.Trim();

            if (_users.Any(u => string.Equals(u.Username, username, StringComparison.OrdinalIgnoreCase)))
            {
                _userError = $"Username {username} already exists.";
                return;
            }

            var tempPassword = UserService.GenerateTempPassword();
            var created = await UserService.CreateAsync(
                _newUserName.Trim(),
                username,
                tempPassword,
                AccessTier.Worker,
                _currentDivisionId);
            created.Position = NormalizeNullable(_newUserPosition);
            await UserService.UpdateAsync(created, null);

            var isPrimary = !ActiveOccupants(_selectedLocker).Any();
            await LockerService.AssignOccupantAsync(_selectedLocker.Id, created.Id, isPrimary, _actorId);
            await UpdateUserLockerFields(created.Id, _selectedLocker);

            _createdUserName = created.Name;
            _createdUserPassword = tempPassword;
            State.PushToast($"{created.Name} created and assigned", "up");
            await RefreshSelected(_selectedLocker.Id);
            _newUserName = "";
            _newUsername = "";
            _newUserPosition = "";
            _userSearch = "";
        }
        catch (Exception ex)
        {
            _userError = ex.Message;
        }
        finally
        {
            _savingUser = false;
        }
    }

    async Task RefreshSelected(string selectedLockerId)
    {
        await Load();
        _selectedLocker = _lockers.FirstOrDefault(l => l.Id == selectedLockerId);
    }

    async Task SyncLegacyLockerFields(Locker locker)
    {
        foreach (var occupant in ActiveOccupants(locker))
        {
            await UpdateUserLockerFields(occupant.UserId, locker);
        }

        foreach (var asset in AssetsInLocker(locker.Id))
        {
            await AssetService.AssignToLockerAsync(asset.Id, locker.Id, locker.Number, _actorId);
        }
    }

    async Task UpdateUserLockerFields(string userId, Locker locker)
    {
        var user = await UserService.GetByIdAsync(userId);
        if (user == null) return;

        user.LockerNumber = locker.Number;
        user.LockerCombo = locker.LockCombo;
        user.LockSerialNumber = locker.LockSerial;
        await UserService.UpdateAsync(user, null);
    }

    async Task ClearUserLockerFields(string userId, string lockerNumber)
    {
        var user = await UserService.GetByIdAsync(userId);
        if (user == null) return;

        if (string.Equals(user.LockerNumber, lockerNumber, StringComparison.OrdinalIgnoreCase))
        {
            user.LockerNumber = null;
            user.LockerCombo = null;
            user.LockSerialNumber = null;
            await UserService.UpdateAsync(user, null);
        }
    }

    void ResetDeviceInputs()
    {
        _deviceSearch = "";
        _deviceSearchResult = null;
        _deviceSearchMissing = false;
        _newDeviceSerial = "";
        _newDeviceModel = "";
        _deviceError = null;
    }

    void ResetUserInputs(bool keepCreatedPassword = false)
    {
        _userSearch = "";
        _newUserName = "";
        _newUsername = "";
        _newUserPosition = "";
        _userError = null;
        if (!keepCreatedPassword)
        {
            _createdUserPassword = null;
            _createdUserName = null;
        }
    }

    List<Locker> FilteredLockers()
    {
        IEnumerable<Locker> q = _lockerFilter switch
        {
            "empty" => _lockers.Where(IsEmptyLocker),
            "attention" => _lockers.Where(LockerHasAttention),
            _ => _lockers,
        };

        if (!string.IsNullOrWhiteSpace(_lockerSearch))
        {
            var s = _lockerSearch.Trim();
            q = q.Where(l =>
                Contains(l.Number, s) ||
                Contains(l.Section, s) ||
                ActiveOccupantUsers(l).Any(u => Contains(u.Name, s) || Contains(u.Username, s)) ||
                AssetsInLocker(l.Id).Any(a => Contains(a.Tag, s) || Contains(a.Serial, s) || Contains(a.Model, s)));
        }

        return q.ToList();
    }

    IEnumerable<LockerOccupant> ActiveOccupants(Locker locker) =>
        locker.Occupants
            .Where(o => o.UnassignedAt == null)
            .OrderByDescending(o => o.IsPrimary)
            .ThenBy(o => o.AssignedAt);

    IEnumerable<User> ActiveOccupantUsers(Locker locker) =>
        ActiveOccupants(locker)
            .Select(o => UserFor(o.UserId))
            .Where(u => u != null)
            .Cast<User>();

    IEnumerable<Asset> AssetsInLocker(string lockerId) =>
        _assets
            .Where(a => a.LockerId == lockerId)
            .OrderBy(a => PrimaryTag(a));

    User? UserFor(string? userId) =>
        string.IsNullOrWhiteSpace(userId)
            ? null
            : _users.FirstOrDefault(u => string.Equals(u.Id, userId, StringComparison.OrdinalIgnoreCase));

    IEnumerable<User> AssignableUsers()
    {
        if (string.IsNullOrWhiteSpace(_currentDivisionId))
        {
            return _users;
        }

        return _users.Where(u => string.Equals(u.DivisionId, _currentDivisionId, StringComparison.OrdinalIgnoreCase));
    }

    bool IsEmptyLocker(Locker locker) =>
        !ActiveOccupants(locker).Any() && !AssetsInLocker(locker.Id).Any();

    bool LockerHasAttention(Locker locker) =>
        AssetsInLocker(locker.Id).Any(a => Format.IsAttentionFlags(a.Flags));

    string LockerCardClass(List<Asset> assets)
    {
        if (assets.Any(a => a.Flags.HasFlag(StatusFlags.Missing))) return "has-missing";
        if (assets.Any(a => Format.IsAttentionFlags(a.Flags))) return "has-attention";
        if (assets.Any(a => a.Flags.HasFlag(StatusFlags.WithHolder) || a.Flags.HasFlag(StatusFlags.OnLoan))) return "has-inuse";
        if (assets.Any()) return "all-available";
        return "";
    }

    static string PrimaryTag(Asset a) =>
        !string.IsNullOrWhiteSpace(a.Tag) ? a.Tag :
        !string.IsNullOrWhiteSpace(a.Serial) ? a.Serial : a.Id;

    static string DeviceSubtitle(Asset asset, User? holder)
    {
        var model = string.IsNullOrWhiteSpace(asset.Model) ? Format.CategoryLabel(asset.Category) : asset.Model;
        return holder == null ? model : $"{model} - {holder.Name}";
    }

    string UniqueUsername(string name)
    {
        var baseName = BuildUsernameBase(name);
        var candidate = baseName;
        var suffix = 2;
        while (_users.Any(u => string.Equals(u.Username, candidate, StringComparison.OrdinalIgnoreCase)))
        {
            candidate = $"{baseName}{suffix++}";
        }

        return candidate;
    }

    static string BuildUsernameBase(string name)
    {
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        var raw = parts.Length >= 2
            ? $"{parts[0][0]}{parts[^1]}"
            : parts.FirstOrDefault() ?? "user";
        var cleaned = new string(raw.Where(char.IsLetterOrDigit).ToArray()).ToLowerInvariant();
        return string.IsNullOrWhiteSpace(cleaned) ? "user" : cleaned;
    }

    static string? NormalizeNullable(string? value) =>
        string.IsNullOrWhiteSpace(value) ? null : value.Trim();

    static int? LockerNumberValue(string number) =>
        int.TryParse(number.Trim(), out var value) ? value : null;

    static bool Contains(string? value, string search) =>
        !string.IsNullOrWhiteSpace(value) &&
        value.Contains(search, StringComparison.OrdinalIgnoreCase);
}
