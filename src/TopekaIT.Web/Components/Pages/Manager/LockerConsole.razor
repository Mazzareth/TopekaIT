@page "/manager/lockers"
@attribute [Authorize(Roles = "Manager,IT,SuperAdmin")]
@using TopekaIT.Core.Domain.Entities
@using TopekaIT.Core.Domain.Enums
@using TopekaIT.Core.Services
@inject UserService UserService
@inject AssetService AssetService

<PageTitle>Locker console · Topeka IT</PageTitle>

<div class="page">
    <div class="page-head">
        <div>
            <h1>Lockers</h1>
            <div class="page-sub">Floor and control center locker assignments.</div>
        </div>
    </div>

    <section style="margin-top: 24px;">
        <h3 style="margin-bottom: 12px;">Floor Lockers</h3>
        <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(140px, 1fr)); gap: 12px;">
            @foreach (var numInt in Enumerable.Range(1, 90))
            {
                var num = numInt.ToString();
                var hasMapping = _lockerMap.TryGetValue(num, out var mapping);
                var isAvailable = !hasMapping || mapping.User == null;
                var hasAttentionDevice = hasMapping && mapping.Asset != null && (mapping.Asset.Status == AssetStatus.InRMA || mapping.Asset.Status == AssetStatus.MIA || mapping.Asset.Status == AssetStatus.Repair || mapping.Asset.Status == AssetStatus.Investigating);
                var bg = isAvailable ? "var(--bg-sunken)" : hasAttentionDevice ? "var(--warn-bg)" : "var(--bg)";
                var border = isAvailable ? "var(--border-subtle)" : hasAttentionDevice ? "var(--warn)" : "var(--border)";
                var opacity = isAvailable ? "0.6" : "1";

                <div style="padding: 12px; background: @bg; border: 1px solid @border; border-radius: 8px; cursor: pointer; opacity: @opacity; display: flex; flex-direction: column; gap: 8px;" @onclick="() => OpenLocker(num)">
                    <div style="display: flex; justify-content: space-between; align-items: center;">
                        <div style="font-weight: bold; font-size: 16px;">#@num</div>
                        @if (hasMapping && mapping.Asset != null)
                        {
                            <Pill Kind="pill-info" Dot>@mapping.Asset.Status.ToString()</Pill>
                        }
                    </div>
                    <div style="font-size: 13px; font-weight: 500; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                        @(isAvailable ? "Open" : mapping.User!.Name)
                    </div>
                    @if (hasMapping && mapping.Asset != null)
                    {
                        <div class="mono" style="font-size: 11px; color: var(--text-dim);">@(mapping.Asset.Tag ?? mapping.Asset.Serial)</div>
                    }
                </div>
            }
        </div>
    </section>

    <section style="margin-top: 32px;">
        <h3 style="margin-bottom: 12px;">Control Center</h3>
        <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(140px, 1fr)); gap: 12px;">
            @foreach (var numInt in Enumerable.Range(110, 6))
            {
                var num = numInt.ToString();
                var hasMapping = _lockerMap.TryGetValue(num, out var mapping);
                var isAvailable = !hasMapping || mapping.User == null;
                var hasAttentionDevice = hasMapping && mapping.Asset != null && (mapping.Asset.Status == AssetStatus.InRMA || mapping.Asset.Status == AssetStatus.MIA || mapping.Asset.Status == AssetStatus.Repair || mapping.Asset.Status == AssetStatus.Investigating);
                var bg = isAvailable ? "var(--bg-sunken)" : hasAttentionDevice ? "var(--warn-bg)" : "var(--bg)";
                var border = isAvailable ? "var(--border-subtle)" : hasAttentionDevice ? "var(--warn)" : "var(--border)";
                var opacity = isAvailable ? "0.6" : "1";

                <div style="padding: 12px; background: @bg; border: 1px solid @border; border-radius: 8px; cursor: pointer; opacity: @opacity; display: flex; flex-direction: column; gap: 8px;" @onclick="() => OpenLocker(num)">
                    <div style="display: flex; justify-content: space-between; align-items: center;">
                        <div style="font-weight: bold; font-size: 16px;">#@num</div>
                        @if (hasMapping && mapping.Asset != null)
                        {
                            <Pill Kind="pill-info" Dot>@mapping.Asset.Status.ToString()</Pill>
                        }
                    </div>
                    <div style="font-size: 13px; font-weight: 500; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                        @(isAvailable ? "Open" : mapping.User!.Name)
                    </div>
                    @if (hasMapping && mapping.Asset != null)
                    {
                        <div class="mono" style="font-size: 11px; color: var(--text-dim);">@(mapping.Asset.Tag ?? mapping.Asset.Serial)</div>
                    }
                </div>
            }
        </div>
    </section>
</div>

<Modal Open="@(_selectedLocker != null)" OnClose="() => _selectedLocker = null" Wide>
    <Title>Locker @_selectedLocker</Title>
    <ChildContent>
        @if (_selectedLocker != null)
        {
            var hasMapping = _lockerMap.TryGetValue(_selectedLocker, out var mapping);
            <div style="display: grid; gap: 24px; grid-template-columns: 1fr 1fr;">
                <div>
                    <h4 style="margin-bottom: 12px; font-size: 13px; text-transform: uppercase; letter-spacing: 0.05em; color: var(--text-faint);">Employee</h4>
                    @if (hasMapping && mapping.User != null)
                    {
                        var u = mapping.User;
                        <div style="margin-bottom: 4px;"><b>@u.Name</b></div>
                        <div style="color: var(--text-dim); margin-bottom: 4px;">@(string.IsNullOrEmpty(u.Position) ? "Employee" : u.Position)</div>
                        <div class="mono" style="font-size: 11px; color: var(--text-faint);">@u.Id</div>
                    }
                    else
                    {
                        <div style="color: var(--text-faint);">Open</div>
                    }

                    <h4 style="margin-top: 24px; margin-bottom: 12px; font-size: 13px; text-transform: uppercase; letter-spacing: 0.05em; color: var(--text-faint);">Locker</h4>
                    @if (hasMapping && mapping.User != null)
                    {
                        var u = mapping.User;
                        <div style="display: grid; gap: 8px;">
                            <div><span style="color: var(--text-dim);">Combo:</span> 
                                @if (_revealCombo) { <span class="mono">@u.LockerCombo</span> }
                                else { <button class="btn btn-sm" style="padding: 2px 6px; height: auto;" @onclick="() => _revealCombo = true">Reveal</button> }
                            </div>
                            <div><span style="color: var(--text-dim);">Lock S/N:</span> <span class="mono">@u.LockSerialNumber</span></div>
                            <div style="margin-top: 8px;">
                                <label style="display: flex; gap: 8px; align-items: center; cursor: pointer;">
                                    <input type="checkbox" checked="@u.Audit" @onchange="(e) => SetAudit(u, (bool?)e.Value ?? false)" />
                                    <span>Audit complete</span>
                                </label>
                            </div>
                        </div>
                    }
                </div>
                <div>
                    <h4 style="margin-bottom: 12px; font-size: 13px; text-transform: uppercase; letter-spacing: 0.05em; color: var(--text-faint);">Device</h4>
                    @if (hasMapping && mapping.Asset != null)
                    {
                        var a = mapping.Asset;
                        <div style="margin-bottom: 8px; display: flex; justify-content: space-between; align-items: flex-start;">
                            <div>
                                <div class="mono" style="margin-bottom: 2px;">@(a.Tag ?? a.Serial)</div>
                                <div style="color: var(--text-dim); font-size: 12px;">@a.Model</div>
                            </div>
                            <Pill Kind="pill-info" Dot>@a.Status.ToString()</Pill>
                        </div>
                        @if (!string.IsNullOrWhiteSpace(a.Notes))
                        {
                            <div style="font-size: 12px; color: var(--text-dim); margin-top: 8px; padding: 8px; background: var(--bg-sunken); border-radius: 4px; white-space: pre-wrap;">@a.Notes</div>
                        }
                        
                        var loan = a.LoanRecords.FirstOrDefault(r => r.DateReturned == null);
                        @if (loan != null)
                        {
                            <div style="margin-top: 12px; padding: 8px; background: var(--warn-bg); border: 1px solid var(--warn); border-radius: 4px; font-size: 12px;">
                                <div style="font-weight: bold; margin-bottom: 2px;">Active Loan</div>
                                <div>Borrower: @loan.BorrowerId</div>
                                <div>Duration: @loan.Duration</div>
                            </div>
                        }
                    }
                    else
                    {
                        <div style="color: var(--text-faint);">No assigned device</div>
                    }
                </div>
            </div>
        }
    </ChildContent>
    <Footer>
        <button class="btn btn-ghost" @onclick="() => _selectedLocker = null">Close</button>
    </Footer>
</Modal>

@code {
    List<User> _users = new();
    List<Asset> _assets = new();
    Dictionary<string, (User User, Asset? Asset)> _lockerMap = new();
    string? _selectedLocker;
    bool _revealCombo;

    protected override async Task OnInitializedAsync()
    {
        _users = (await UserService.GetAllAsync()).ToList();
        _assets = (await AssetService.GetAllAsync()).ToList();
        
        var assetByHolder = _assets.Where(a => !string.IsNullOrEmpty(a.HolderId)).GroupBy(a => a.HolderId!).ToDictionary(g => g.Key, g => g.First());

        foreach (var u in _users)
        {
            if (!string.IsNullOrWhiteSpace(u.LockerNumber))
            {
                var a = assetByHolder.GetValueOrDefault(u.Id);
                _lockerMap[u.LockerNumber] = (u, a);
            }
        }
    }

    void OpenLocker(string num)
    {
        _selectedLocker = num;
        _revealCombo = false;
    }

    async Task SetAudit(User u, bool val)
    {
        u.Audit = val;
        await UserService.SetAuditAsync(u.Id, val);
    }
}
