@* Login page. The form posts to MVC so antiforgery and cookie auth stay boring and reliable. *@
@page "/login"
@layout LoginLayout
@attribute [AllowAnonymous]

<PageTitle>Sign in · Local Warehouse Operations Portal</PageTitle>

<div class="login-stack">
    <div class="login-card">
        <div class="login-brand">
            <div class="login-title">Local Warehouse Operations Portal</div>
        </div>
        @if (!string.IsNullOrEmpty(ErrorMessage))
        {
            <div class="login-error">@ErrorMessage</div>
        }
        <form method="post" action="/auth/login">
            <AntiforgeryToken />
            <input type="hidden" name="ReturnUrl" value="@ReturnUrl" />
            <div class="form-row">
                <label>Username</label>
                <input name="Username" autofocus autocomplete="username" required />
            </div>
            <div class="form-row">
                <label>Password</label>
                <input name="Password" type="password" autocomplete="current-password" required />
            </div>
            <button class="btn btn-accent btn-block" type="submit">Sign in</button>
        </form>
    </div>

    <a class="btn btn-block login-station-link" href="/station/equipment">Use Device Check-In Station</a>
</div>

@code {
    [SupplyParameterFromQuery] public string? ErrorMessage { get; set; }
    [SupplyParameterFromQuery] public string? ReturnUrl { get; set; }
}
