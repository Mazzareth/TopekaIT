<Application x:Class="TopekaIT.DeploymentChecker.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <SolidColorBrush x:Key="SurfaceBrush" Color="#F5EFE6" />
        <SolidColorBrush x:Key="PanelBrush" Color="#FFFDF8" />
        <SolidColorBrush x:Key="PanelAltBrush" Color="#F1E7DA" />
        <SolidColorBrush x:Key="TerminalBrush" Color="#FFF8ED" />
        <SolidColorBrush x:Key="LineBrush" Color="#DECBBB" />
        <SolidColorBrush x:Key="LineStrongBrush" Color="#B88472" />
        <SolidColorBrush x:Key="InkBrush" Color="#33241F" />
        <SolidColorBrush x:Key="MutedBrush" Color="#765F56" />
        <SolidColorBrush x:Key="SubtleBrush" Color="#9D8275" />
        <SolidColorBrush x:Key="AccentBrush" Color="#743542" />
        <SolidColorBrush x:Key="AccentDimBrush" Color="#F2DFD8" />
        <SolidColorBrush x:Key="OkBrush" Color="#5D7E55" />
        <SolidColorBrush x:Key="DownBrush" Color="#A84842" />
        <SolidColorBrush x:Key="WarnBrush" Color="#A76A2C" />
    </Application.Resources>
</Application>
