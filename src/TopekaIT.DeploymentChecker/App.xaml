<Application x:Class="TopekaIT.DeploymentChecker.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <SolidColorBrush x:Key="SurfaceBrush" Color="#090B0A" />
        <SolidColorBrush x:Key="PanelBrush" Color="#101412" />
        <SolidColorBrush x:Key="PanelAltBrush" Color="#141A17" />
        <SolidColorBrush x:Key="TerminalBrush" Color="#050706" />
        <SolidColorBrush x:Key="LineBrush" Color="#26332D" />
        <SolidColorBrush x:Key="LineStrongBrush" Color="#395045" />
        <SolidColorBrush x:Key="InkBrush" Color="#E7F5EA" />
        <SolidColorBrush x:Key="MutedBrush" Color="#829088" />
        <SolidColorBrush x:Key="SubtleBrush" Color="#55635B" />
        <SolidColorBrush x:Key="AccentBrush" Color="#5EE787" />
        <SolidColorBrush x:Key="AccentDimBrush" Color="#1D3D2B" />
        <SolidColorBrush x:Key="OkBrush" Color="#5EE787" />
        <SolidColorBrush x:Key="DownBrush" Color="#FF6B6B" />
        <SolidColorBrush x:Key="WarnBrush" Color="#F5C542" />
