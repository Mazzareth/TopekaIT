<Window x:Class="TopekaIT.DeploymentChecker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Topeka IT Deploy Console"
        Height="760"
        Width="1120"
        MinHeight="680"
        MinWidth="980"
        Icon="Assets/DeployChecker.ico"
        Background="{StaticResource SurfaceBrush}"
        FontFamily="Cascadia Mono, Consolas"
        Loaded="Window_Loaded">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Margin" Value="0,0,0,5" />
        </Style>

        <Style x:Key="Panel" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="9,6" />
            <Setter Property="Background" Value="{StaticResource PanelAltBrush}" />
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="CaretBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource LineStrongBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="SelectionBrush" Value="{StaticResource AccentDimBrush}" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Style.Triggers>
                <Trigger Property="IsReadOnly" Value="True">
                    <Setter Property="Background" Value="{StaticResource TerminalBrush}" />
                    <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="PasswordBox">
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="9,6" />
            <Setter Property="Background" Value="{StaticResource PanelAltBrush}" />
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="CaretBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource LineStrongBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="{StaticResource TerminalBrush}" />
                    <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="Background" Value="{StaticResource PanelAltBrush}" />
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource LineStrongBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="AccentButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource AccentDimBrush}" />
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{StaticResource Panel}"
                Background="{StaticResource TerminalBrush}"
                Padding="16"
                Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="TOPEKA::DEPLOY_CONSOLE"
                               Foreground="{StaticResource AccentBrush}"
                               FontSize="22"
                               FontWeight="Bold" />
                    <TextBlock Text="remote status / release push / service control"
                               Margin="0,5,0,0"
                               Foreground="{StaticResource MutedBrush}" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="EditButton"
                            Content="EDIT"
                            Width="92"
                            Margin="0,0,8,0"
                            Click="EditButton_Click" />
                    <Button x:Name="CheckButton"
                            Content="CHECK"
                            Width="96"
                            Margin="0,0,8,0"
                            Click="CheckButton_Click" />
                    <Button x:Name="PushButton"
                            Style="{StaticResource AccentButton}"
                            Content="PUSH UPDATES"
                            Width="138"
                            Click="PushButton_Click" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Style="{StaticResource Panel}"
                    Margin="0,0,12,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,10,10">
                        <TextBlock Style="{StaticResource FieldLabel}" Text="REMOTE_SERVER" />
                        <TextBox x:Name="RemoteServerBox" />
                    </StackPanel>
                    <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,10">
                        <TextBlock Style="{StaticResource FieldLabel}" Text="SERVICE" />
                        <TextBox x:Name="ServiceNameBox" />
                    </StackPanel>
                    <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,0,10">
                        <TextBlock Style="{StaticResource FieldLabel}" Text="REMOTE_PATH" />
                        <TextBox x:Name="RemotePathBox" />
                    </StackPanel>
                    <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,10,0">
                        <TextBlock Style="{StaticResource FieldLabel}" Text="USERNAME" />
                        <TextBox x:Name="UsernameBox" />
                    </StackPanel>
                    <StackPanel Grid.Row="2" Grid.Column="1">
                        <TextBlock Style="{StaticResource FieldLabel}" Text="PASSWORD" />
                        <PasswordBox x:Name="PasswordBox" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource Panel}">
                <StackPanel>
                    <TextBlock Text="STATUS"
                               Foreground="{StaticResource MutedBrush}"
                               FontSize="11" />
                    <TextBlock x:Name="StatusText"
                               Text="IDLE"
                               Margin="0,7,0,0"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="{StaticResource WarnBrush}" />
                    <TextBlock x:Name="ReasonText"
                               Text="Awaiting command."
                               Margin="0,10,0,0"
                               TextWrapping="Wrap"
                               Foreground="{StaticResource InkBrush}" />
                    <TextBlock x:Name="LogPathText"
                               Margin="0,14,0,0"
                               TextWrapping="Wrap"
                               Foreground="{StaticResource SubtleBrush}"
                               FontSize="11" />
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.45*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Style="{StaticResource Panel}"
                    Background="{StaticResource TerminalBrush}"
                    Margin="0,0,12,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Text="$ terminal"
                               Foreground="{StaticResource AccentBrush}"
                               FontWeight="Bold"
                               Margin="0,0,0,10" />
                    <TextBox x:Name="TerminalBox"
                             IsReadOnly="True"
                             AcceptsReturn="True"
                             TextWrapping="NoWrap"
                             HorizontalScrollBarVisibility="Auto"
                             VerticalScrollBarVisibility="Auto"
                             VerticalContentAlignment="Top"
                             Background="{StaticResource TerminalBrush}"
                             Foreground="{StaticResource AccentBrush}"
                             BorderThickness="0"
                             FontSize="12.5" />
                </DockPanel>
            </Border>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="1.05*" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Style="{StaticResource Panel}"
                        Margin="0,0,0,12">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top"
                                   Text="LAST_RESULT"
                                   Foreground="{StaticResource MutedBrush}"
                                   FontWeight="Bold"
                                   Margin="0,0,0,8" />
                        <TextBox x:Name="DetailBox"
                                 IsReadOnly="True"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 VerticalContentAlignment="Top"
                                 Background="{StaticResource PanelBrush}"
                                 Foreground="{StaticResource InkBrush}"
                                 BorderThickness="0"
                                 FontSize="12" />
                    </DockPanel>
                </Border>

                <Border Grid.Row="1" Style="{StaticResource Panel}">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top"
                                   Text="RECENT_CHECKS"
                                   Foreground="{StaticResource MutedBrush}"
                                   FontWeight="Bold"
                                   Margin="0,0,0,8" />
                        <TextBox x:Name="HistoryBox"
                                 IsReadOnly="True"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 VerticalContentAlignment="Top"
                                 Background="{StaticResource PanelBrush}"
                                 Foreground="{StaticResource InkBrush}"
                                 BorderThickness="0"
                                 FontSize="12" />
                    </DockPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
