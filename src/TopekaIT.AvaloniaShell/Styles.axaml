<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Style Selector="TextBlock.heading">
    <Setter Property="Foreground" Value="{DynamicResource ShellTextBrush}" />
    <Setter Property="FontSize" Value="30" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="LineHeight" Value="36" />
  </Style>

  <Style Selector="TextBlock.section-title">
    <Setter Property="Foreground" Value="{DynamicResource ShellTextBrush}" />
    <Setter Property="FontSize" Value="20" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>

  <Style Selector="TextBlock.body">
    <Setter Property="Foreground" Value="{DynamicResource ShellMutedTextBrush}" />
    <Setter Property="FontSize" Value="14" />
    <Setter Property="LineHeight" Value="20" />
  </Style>

  <Style Selector="TextBlock.label">
    <Setter Property="Foreground" Value="{DynamicResource ShellMutedTextBrush}" />
    <Setter Property="FontSize" Value="13" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>

  <Style Selector="TextBlock.status">
    <Setter Property="Foreground" Value="{DynamicResource ShellMutedTextBrush}" />
    <Setter Property="FontSize" Value="13" />
    <Setter Property="LineHeight" Value="18" />
  </Style>

  <Style Selector="Border.panel">
    <Setter Property="Background" Value="{DynamicResource ShellPanelBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource ShellBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="8" />
    <Setter Property="Padding" Value="24" />
    <Setter Property="MinHeight" Value="390" />
  </Style>

  <Style Selector="Border.hub-nav-panel">
    <Setter Property="MinHeight" Value="0" />
    <Setter Property="Padding" Value="18" />
  </Style>

  <Style Selector="Border.hub-detail-panel">
    <Setter Property="MinHeight" Value="0" />
  </Style>

  <Style Selector="Border.surface">
    <Setter Property="Background" Value="{DynamicResource ShellPanelAltBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource ShellBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="8" />
    <Setter Property="Padding" Value="14" />
  </Style>

  <Style Selector="Border.status-surface">
    <Setter Property="Padding" Value="12" />
  </Style>

  <Style Selector="TextBox.prototype-input">
    <Setter Property="Height" Value="42" />
    <Setter Property="FontSize" Value="15" />
    <Setter Property="Padding" Value="12,0" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
  </Style>

  <Style Selector="Button.action">
    <Setter Property="Height" Value="42" />
    <Setter Property="MinWidth" Value="128" />
    <Setter Property="Padding" Value="18,0" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
    <Setter Property="FontSize" Value="14" />
    <Setter Property="FontWeight" Value="Medium" />
  </Style>

  <Style Selector="Button.secondary">
    <Setter Property="Height" Value="36" />
    <Setter Property="MinWidth" Value="104" />
    <Setter Property="Padding" Value="14,0" />
    <Setter Property="FontSize" Value="13" />
  </Style>

  <Style Selector="Button.tile">
    <Setter Property="MinHeight" Value="64" />
    <Setter Property="Padding" Value="12" />
    <Setter Property="Margin" Value="0,0,0,8" />
    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
  </Style>

  <Style Selector="TextBlock.tile-title">
    <Setter Property="Foreground" Value="{DynamicResource ShellTextBrush}" />
    <Setter Property="FontSize" Value="14" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>

  <Style Selector="TextBlock.tile-subtitle">
    <Setter Property="Foreground" Value="{DynamicResource ShellMutedTextBrush}" />
    <Setter Property="FontSize" Value="12" />
    <Setter Property="LineHeight" Value="16" />
  </Style>

  <Style Selector="TextBlock.tile-state">
    <Setter Property="Foreground" Value="{DynamicResource ShellAccentBrush}" />
    <Setter Property="FontSize" Value="11" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>
</Styles>
